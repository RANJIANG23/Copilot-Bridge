{
  "allowedHost": "m365.cloud.microsoft",
  "modelSwitcher": [
    "button#gptModeSwitcher",
    "[data-testid='gpt-mode-switcher']"
  ],
  "composer": [
    "textarea[placeholder*='消息']",
    "textarea[placeholder*='输入']",
    "textarea[placeholder*='Ask']",
    "textarea[placeholder*='Message']",
    "[contenteditable='true'][role='textbox']"
  ],
  "sendButton": [
    "button[aria-label*='发送']",
    "button[aria-label*='Send']",
    "button[data-testid*='send']"
  ],
  "userMessages": "[data-testid='chatQuestion'], [data-message-author-role='user']:not(:has([data-testid='chatQuestion']))",
  "assistantMessages": "[data-testid='copilot-message-reply-div'], [data-message-author-role='assistant']:not(:has([data-testid='copilot-message-reply-div']))",
  "busy": "[aria-busy='true'], button[aria-label*='停止'], button[aria-label*='Stop'], button[data-testid*='stop']",
  "opus": "Opus",
  "gptParent": "GPT",
  "gpt56": "GPT 5.6 Think deeper",
  "deepThinkingChinese": "深度思考",
  "deepThinkingEnglish": "Think deeper"
}
