<Window x:Class="CopilotBridge.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Copilot Bridge" Width="1400" Height="860" MinWidth="1080" MinHeight="700"
        WindowStartupLocation="CenterScreen" Background="{DynamicResource CanvasBrush}"
        FontFamily="./Resources/Fonts/#Noto Sans SC" Foreground="{DynamicResource TextPrimaryBrush}"
        AutomationProperties.Name="Copilot Bridge" Loaded="Window_Loaded">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Theme/CopilotTheme.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>
    <Grid>
        <Grid.ColumnDefinitions><ColumnDefinition Width="264" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
        <Border Grid.Column="0" Background="{DynamicResource SidebarBrush}" BorderBrush="{DynamicResource LineBrush}" BorderThickness="0,0,1,0">
            <Grid><Grid.RowDefinitions><RowDefinition Height="104" /><RowDefinition Height="*" /><RowDefinition Height="Auto" /></Grid.RowDefinitions>
                <StackPanel Orientation="Horizontal" Margin="24,26" VerticalAlignment="Center"><Border Width="36" Height="36" Background="{DynamicResource SoftSurfaceBrush}" BorderBrush="{DynamicResource LineBrush}" BorderThickness="1" CornerRadius="10"><TextBlock Text="&#xE71B;" FontFamily="Segoe Fluent Icons" FontSize="16" Foreground="{DynamicResource TextPrimaryBrush}" HorizontalAlignment="Center" VerticalAlignment="Center" /></Border><StackPanel Margin="12,0" VerticalAlignment="Center"><TextBlock Text="Copilot Bridge" FontSize="17" FontWeight="SemiBold" LineHeight="23" /><TextBlock Text="v1.3.0 协作模式设定" FontSize="12" LineHeight="18" Foreground="{DynamicResource SubtleTextBrush}" /></StackPanel></StackPanel>
                <StackPanel Grid.Row="1" Margin="0,10">
                    <Button x:Name="OverviewNav" AutomationProperties.Name="概览" Style="{StaticResource NavButtonStyle}" Tag="overview" Click="Navigation_Click"><StackPanel Orientation="Horizontal"><TextBlock Text="&#xE80F;" FontFamily="Segoe Fluent Icons" Width="30" /><TextBlock Text="概览" /></StackPanel></Button>
                    <Button x:Name="StatisticsNav" AutomationProperties.Name="数据统计" Style="{StaticResource NavButtonStyle}" Tag="statistics" Click="Navigation_Click"><StackPanel Orientation="Horizontal"><TextBlock Text="&#xE9D2;" FontFamily="Segoe Fluent Icons" Width="30" /><TextBlock Text="数据统计" /></StackPanel></Button>
                    <Button x:Name="HistoryNav" AutomationProperties.Name="对话管理" Style="{StaticResource NavButtonStyle}" Tag="history" Click="Navigation_Click"><StackPanel Orientation="Horizontal"><TextBlock Text="&#xE81C;" FontFamily="Segoe Fluent Icons" Width="30" /><TextBlock Text="对话管理" /></StackPanel></Button>
                    <Button x:Name="CollaborationNav" AutomationProperties.Name="协作默认设置" Style="{StaticResource NavButtonStyle}" Tag="collaboration" Click="Navigation_Click"><StackPanel Orientation="Horizontal"><TextBlock Text="&#xE902;" FontFamily="Segoe Fluent Icons" Width="30" /><TextBlock Text="协作默认设置" /></StackPanel></Button>
                    <Button x:Name="BrowserNav" AutomationProperties.Name="浏览器与模型" Style="{StaticResource NavButtonStyle}" Tag="browser" Click="Navigation_Click"><StackPanel Orientation="Horizontal"><TextBlock Text="&#xE774;" FontFamily="Segoe Fluent Icons" Width="30" /><TextBlock Text="浏览器与模型" /></StackPanel></Button>
                    <Button x:Name="SettingsNav" AutomationProperties.Name="设置" Style="{StaticResource NavButtonStyle}" Tag="settings" Click="Navigation_Click"><StackPanel Orientation="Horizontal"><TextBlock Text="&#xE713;" FontFamily="Segoe Fluent Icons" Width="30" /><TextBlock Text="设置" /></StackPanel></Button>
                </StackPanel>
                <StackPanel Grid.Row="2" Margin="24,18,24,24"><Separator Background="{DynamicResource LineBrush}" /><TextBlock Text="数据保存在你的本地工作区" FontSize="11" Foreground="{DynamicResource MutedTextBrush}" Margin="0,14,0,0" TextWrapping="Wrap" /></StackPanel>
            </Grid>
        </Border>
        <Grid Grid.Column="1"><Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /><RowDefinition Height="*" /></Grid.RowDefinitions>
            <Grid Margin="40,22,40,0" MaxWidth="1080"><Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions><StackPanel Orientation="Horizontal"><Border Width="8" Height="8" CornerRadius="4" Background="{DynamicResource StatusUnknownBrush}" VerticalAlignment="Center" Margin="0,0,9,0" /><StackPanel><TextBlock x:Name="HeaderStatusText" Text="正在初始化" AutomationProperties.Name="连接状态" AutomationProperties.LiveSetting="Polite" FontSize="12" Foreground="{DynamicResource SubtleTextBrush}" VerticalAlignment="Center" /><TextBlock x:Name="BusyHintText" Foreground="{DynamicResource SubtleTextBrush}" FontSize="11" Margin="0,2,0,0" Visibility="Collapsed" /></StackPanel></StackPanel><ProgressBar x:Name="BusyProgress" Grid.Column="1" Width="110" Height="3" IsIndeterminate="True" Visibility="Collapsed" /></Grid>
            <Border x:Name="NoticeBorder" Grid.Row="1" Margin="40,12,40,0" MaxWidth="1080" Padding="16,12" Background="{DynamicResource NoticeInfoBackgroundBrush}" BorderBrush="{DynamicResource NoticeInfoBorderBrush}" BorderThickness="1" CornerRadius="12" Visibility="Collapsed"><Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions><TextBlock x:Name="NoticeText" AutomationProperties.Name="状态提示" AutomationProperties.LiveSetting="Polite" TextWrapping="Wrap" Foreground="{DynamicResource NoticeInfoTextBrush}" VerticalAlignment="Center" /><Button x:Name="NoticeCloseButton" Grid.Column="1" Content="×" FontSize="18" FontWeight="SemiBold" Foreground="{DynamicResource NoticeInfoTextBrush}" Background="Transparent" BorderThickness="0" Padding="10,0,0,0" ToolTip="关闭提示" AutomationProperties.Name="关闭提示" Click="NoticeClose_Click" /></Grid></Border>
            <Grid Grid.Row="2">
                <Grid x:Name="OverviewPanel"><ScrollViewer VerticalScrollBarVisibility="Auto"><StackPanel Margin="40,34,40,48" MaxWidth="1000">
                    <TextBlock Text="概览" Style="{StaticResource PageTitleStyle}" /><TextBlock Text="检查后台连接状态，并管理专用 Copilot 标签页绑定。" Style="{StaticResource PageDescriptionStyle}" />
                    <Border Style="{StaticResource CardStyle}"><Grid><Grid.RowDefinitions><RowDefinition Height="60" /><RowDefinition Height="60" /><RowDefinition Height="60" /><RowDefinition Height="60" /></Grid.RowDefinitions><Grid.ColumnDefinitions><ColumnDefinition Width="190" /><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                        <TextBlock Text="Edge 连接" Margin="20,0" VerticalAlignment="Center" Foreground="{DynamicResource SubtleTextBrush}" /><TextBlock x:Name="EdgeStatusText" Grid.Column="1" VerticalAlignment="Center" FontWeight="SemiBold" Text="尚未检查" /><Ellipse x:Name="EdgeStatusDot" Grid.Column="2" Width="9" Height="9" Fill="{DynamicResource StatusUnknownBrush}" Margin="20" />
                        <TextBlock Grid.Row="1" Text="专用标签页" Margin="20,0" VerticalAlignment="Center" Foreground="{DynamicResource SubtleTextBrush}" /><TextBlock x:Name="TabStatusText" Grid.Row="1" Grid.Column="1" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" Text="未绑定" />
                        <TextBlock Grid.Row="2" Text="Microsoft 365 登录" Margin="20,0" VerticalAlignment="Center" Foreground="{DynamicResource SubtleTextBrush}" /><TextBlock x:Name="LoginStatusText" Grid.Row="2" Grid.Column="1" VerticalAlignment="Center" Text="未知" />
                        <TextBlock Grid.Row="3" Text="页面当前模型" Margin="20,0" VerticalAlignment="Center" Foreground="{DynamicResource SubtleTextBrush}" /><TextBlock x:Name="ModelStatusText" Grid.Row="3" Grid.Column="1" VerticalAlignment="Center" Text="未知" />
                    </Grid></Border>
                    <StackPanel Orientation="Horizontal" Margin="0,16,0,5"><Button x:Name="RefreshButton" Content="刷新状态" Style="{StaticResource SecondaryButtonStyle}" Click="Refresh_Click" /></StackPanel>
                    <TextBlock x:Name="AutoRefreshStatusText" Text="自动刷新正在准备。" Foreground="{DynamicResource SubtleTextBrush}" FontSize="12" Margin="0,0,0,30" />
                    <TextBlock Text="标签页绑定" Style="{StaticResource SectionTitleStyle}" /><TextBlock Text="将 Bridge 绑定到当前已登录的专用 Copilot 标签页。" Foreground="{DynamicResource SubtleTextBrush}" Margin="0,6,0,14" /><Border Style="{StaticResource CardStyle}" Padding="20,18"><Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions><StackPanel><TextBlock Text="当前绑定" Foreground="{DynamicResource SubtleTextBrush}" FontSize="12" /><TextBlock x:Name="BoundUrlText" Text="未绑定" Margin="0,7,24,0" TextTrimming="CharacterEllipsis" /></StackPanel><Button x:Name="BindButton" Grid.Column="1" Content="绑定当前 Copilot 标签页" Style="{StaticResource PrimaryButtonStyle}" Click="Bind_Click" /></Grid></Border>
                    <Border Style="{StaticResource CardStyle}" Padding="22" Margin="0,16,0,0"><Grid><Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /></Grid.RowDefinitions><Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions><StackPanel><TextBlock Text="即时咨询" Style="{StaticResource SectionTitleStyle}" /><TextBlock Text="发送后会保存发送内容、Copilot 回复和已验证的实际模型；不会自动导入旧网页历史。" Foreground="{DynamicResource SubtleTextBrush}" Margin="0,6,0,0" /></StackPanel><Button x:Name="TestButton" Grid.Column="1" Content="发送并记录即时咨询" Style="{StaticResource PrimaryButtonStyle}" VerticalAlignment="Top" Margin="24,0,0,0" Click="Test_Click" /></Grid><TextBox x:Name="TestPromptTextBox" Grid.Row="1" Height="120" Margin="0,16,0,0" AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" Text="这是 Copilot Bridge v1.1 即时会话测试。请只回复：COPILOT_BRIDGE_V11_OK" /></Grid></Border>
                </StackPanel></ScrollViewer></Grid>
                <Grid x:Name="StatisticsPanel" Visibility="Collapsed"><ScrollViewer VerticalScrollBarVisibility="Auto"><StackPanel Margin="40,34,40,48" MaxWidth="1000">
                    <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions><StackPanel><TextBlock Text="数据统计" Style="{StaticResource PageTitleStyle}" /><TextBlock Text="查看 Bridge 向 Copilot 交付的任务、可见文本 Token 和 API 等效费用。" Style="{StaticResource PageDescriptionStyle}" /></StackPanel><StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Top"><ComboBox x:Name="StatisticsRangeComboBox" Width="150" SelectedIndex="1" SelectionChanged="StatisticsRange_SelectionChanged"><ComboBoxItem Content="最近 7 天" /><ComboBoxItem Content="最近 30 天" /><ComboBoxItem Content="全部记录" /><ComboBoxItem Content="自定义" /></ComboBox><Button Content="刷新统计" Style="{StaticResource SecondaryButtonStyle}" Margin="10,0,0,0" Click="RefreshStatistics_Click" /></StackPanel></Grid>
                    <StackPanel x:Name="StatisticsCustomRangePanel" Orientation="Horizontal" Visibility="Collapsed" Margin="0,16,0,0" HorizontalAlignment="Right"><TextBlock Text="从" VerticalAlignment="Center" Margin="0,0,8,0" /><DatePicker x:Name="StatisticsFromDatePicker" Width="150" /><TextBlock Text="到" VerticalAlignment="Center" Margin="12,0,8,0" /><DatePicker x:Name="StatisticsToDatePicker" Width="150" /><Button Content="应用" Style="{StaticResource SecondaryButtonStyle}" Margin="10,0,0,0" Click="ApplyStatisticsRange_Click" /></StackPanel>
                    <WrapPanel Margin="0,22,0,0">
                        <Border Width="235" Style="{StaticResource CardStyle}" Padding="20" Margin="0,0,12,12"><StackPanel><TextBlock Text="Copilot 交付次数" Foreground="{DynamicResource SubtleTextBrush}" /><TextBlock x:Name="StatisticsDeliveryText" Text="0" FontSize="30" FontWeight="SemiBold" Margin="0,8,0,0" /><TextBlock x:Name="StatisticsTaskText" Text="0 个协作任务" FontSize="12" Foreground="{DynamicResource MutedTextBrush}" Margin="0,4,0,0" /></StackPanel></Border>
                        <Border Width="235" Style="{StaticResource CardStyle}" Padding="20" Margin="0,0,12,12"><StackPanel><TextBlock Text="已完成与完成率" Foreground="{DynamicResource SubtleTextBrush}" /><TextBlock x:Name="StatisticsCompletedText" Text="0 · 0%" FontSize="30" FontWeight="SemiBold" Margin="0,8,0,0" /><TextBlock Text="仅统计已保存的本地记录" FontSize="12" Foreground="{DynamicResource MutedTextBrush}" Margin="0,4,0,0" /></StackPanel></Border>
                        <Border Width="235" Style="{StaticResource CardStyle}" Padding="20" Margin="0,0,12,12"><StackPanel><TextBlock Text="等效处理 Token" Foreground="{DynamicResource SubtleTextBrush}" /><TextBlock x:Name="StatisticsTokenText" Text="0" FontSize="30" FontWeight="SemiBold" Margin="0,8,0,0" /><TextBlock x:Name="StatisticsTokenRangeText" Text="估算区间 0–0" FontSize="12" Foreground="{DynamicResource MutedTextBrush}" TextWrapping="Wrap" Margin="0,4,0,0" /></StackPanel></Border>
                        <Border Width="235" Style="{StaticResource CardStyle}" Padding="20" Margin="0,0,0,12"><StackPanel><TextBlock Text="API 等效费用" Foreground="{DynamicResource SubtleTextBrush}" /><TextBlock x:Name="StatisticsCostText" Text="$0.0000" FontSize="30" FontWeight="SemiBold" Margin="0,8,0,0" /><TextBlock x:Name="StatisticsCostRangeText" Text="估算区间 $0–$0" FontSize="12" Foreground="{DynamicResource MutedTextBrush}" Margin="0,4,0,0" /></StackPanel></Border>
                    </WrapPanel>
                    <Border Style="{StaticResource CardStyle}" Padding="22" Margin="0,4,0,0"><StackPanel><Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions><StackPanel><TextBlock Text="交付趋势" Style="{StaticResource SectionTitleStyle}" /><TextBlock x:Name="StatisticsPeriodText" Text="正在读取本地记录" Foreground="{DynamicResource SubtleTextBrush}" FontSize="12" Margin="0,5,0,0" /></StackPanel><TextBlock x:Name="StatisticsTrendGranularityText" Grid.Column="1" Text="按日" Foreground="{DynamicResource MutedTextBrush}" FontSize="12" VerticalAlignment="Bottom" /></Grid><ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled" Margin="0,18,0,0"><ItemsControl x:Name="StatisticsTrendItems"><ItemsControl.ItemsPanel><ItemsPanelTemplate><StackPanel Orientation="Horizontal" /></ItemsPanelTemplate></ItemsControl.ItemsPanel><ItemsControl.ItemTemplate><DataTemplate><StackPanel Width="44"><Grid Height="132"><Border Width="18" Height="{Binding BarHeight}" MinHeight="2" VerticalAlignment="Bottom" CornerRadius="5,5,2,2" Background="{DynamicResource AccentBrush}" ToolTip="{Binding Tooltip}" /></Grid><TextBlock Text="{Binding Label}" FontSize="10" Foreground="{DynamicResource MutedTextBrush}" HorizontalAlignment="Center" Margin="0,6,0,0" /></StackPanel></DataTemplate></ItemsControl.ItemTemplate></ItemsControl></ScrollViewer></StackPanel></Border>
                    <Border Style="{StaticResource CardStyle}" Padding="22" Margin="0,16,0,0"><StackPanel><TextBlock Text="模型使用与费用" Style="{StaticResource SectionTitleStyle}" /><TextBlock Text="费用使用原型费率并乘内部开销倍率；未知模型不会静默套价。" Foreground="{DynamicResource SubtleTextBrush}" FontSize="12" Margin="0,5,0,16" /><Grid Margin="0,0,0,8"><Grid.ColumnDefinitions><ColumnDefinition Width="2.2*" /><ColumnDefinition Width="0.8*" /><ColumnDefinition Width="1*" /><ColumnDefinition Width="1*" /><ColumnDefinition Width="1.1*" /></Grid.ColumnDefinitions><TextBlock Text="模型" FontWeight="SemiBold" /><TextBlock Grid.Column="1" Text="交付" FontWeight="SemiBold" HorizontalAlignment="Right" /><TextBlock Grid.Column="2" Text="输入 Token" FontWeight="SemiBold" HorizontalAlignment="Right" /><TextBlock Grid.Column="3" Text="输出 Token" FontWeight="SemiBold" HorizontalAlignment="Right" /><TextBlock Grid.Column="4" Text="等效费用" FontWeight="SemiBold" HorizontalAlignment="Right" /></Grid><ItemsControl x:Name="StatisticsModelItems"><ItemsControl.ItemTemplate><DataTemplate><Grid MinHeight="42"><Grid.ColumnDefinitions><ColumnDefinition Width="2.2*" /><ColumnDefinition Width="0.8*" /><ColumnDefinition Width="1*" /><ColumnDefinition Width="1*" /><ColumnDefinition Width="1.1*" /></Grid.ColumnDefinitions><TextBlock Text="{Binding Model}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" /><TextBlock Grid.Column="1" Text="{Binding Deliveries}" VerticalAlignment="Center" HorizontalAlignment="Right" /><TextBlock Grid.Column="2" Text="{Binding InputTokens}" VerticalAlignment="Center" HorizontalAlignment="Right" /><TextBlock Grid.Column="3" Text="{Binding OutputTokens}" VerticalAlignment="Center" HorizontalAlignment="Right" /><TextBlock Grid.Column="4" Text="{Binding Cost}" VerticalAlignment="Center" HorizontalAlignment="Right" /></Grid></DataTemplate></ItemsControl.ItemTemplate></ItemsControl></StackPanel></Border>
                    <Grid Margin="0,16,0,0"><Grid.ColumnDefinitions><ColumnDefinition Width="1*" /><ColumnDefinition Width="1*" /></Grid.ColumnDefinitions><Border Style="{StaticResource CardStyle}" Padding="22" Margin="0,0,8,0"><StackPanel><TextBlock Text="协作模式" Style="{StaticResource SectionTitleStyle}" /><ItemsControl x:Name="StatisticsModeItems" Margin="0,12,0,0"><ItemsControl.ItemTemplate><DataTemplate><Grid MinHeight="34"><Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions><TextBlock Text="{Binding Mode}" /><TextBlock Grid.Column="1" Text="{Binding Summary}" Foreground="{DynamicResource SubtleTextBrush}" /></Grid></DataTemplate></ItemsControl.ItemTemplate></ItemsControl></StackPanel></Border><Border Grid.Column="1" Style="{StaticResource CardStyle}" Padding="22" Margin="8,0,0,0"><StackPanel><TextBlock Text="估算参数" Style="{StaticResource SectionTitleStyle}" /><TextBlock Text="内部开销倍率" Foreground="{DynamicResource SubtleTextBrush}" Margin="0,12,0,0" /><Grid Margin="0,7,0,0"><Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="70" /></Grid.ColumnDefinitions><Slider x:Name="StatisticsMultiplierSlider" Minimum="1" Maximum="6" Value="3" TickFrequency="0.5" IsSnapToTickEnabled="True" ValueChanged="StatisticsMultiplier_ValueChanged" /><TextBlock x:Name="StatisticsMultiplierText" Grid.Column="1" Text="3.0×" HorizontalAlignment="Right" VerticalAlignment="Center" FontWeight="SemiBold" /></Grid><Button Content="保存倍率" Style="{StaticResource SecondaryButtonStyle}" HorizontalAlignment="Left" Margin="0,12,0,0" Click="SaveStatisticsMultiplier_Click" /><TextBlock Text="原型费率（输入 / 输出，每 1M Token）" FontWeight="SemiBold" Margin="0,16,0,6" /><TextBlock Text="Claude Opus 4.8　$5 / $25" Foreground="{DynamicResource SubtleTextBrush}" FontSize="12" /><TextBlock Text="GPT-5.6 Think deeper　$5 / $30" Foreground="{DynamicResource SubtleTextBrush}" FontSize="12" Margin="0,3,0,0" /><TextBlock Text="GPT-5.5 Instant　$5 / $30" Foreground="{DynamicResource SubtleTextBrush}" FontSize="12" Margin="0,3,0,0" /><TextBlock Text="默认 3×；区间至少覆盖 2×–5×，并包含当前倍率。仅为 API 等效估算，不代表 Microsoft 365 Copilot 实际账单。" Foreground="{DynamicResource MutedTextBrush}" FontSize="11" TextWrapping="Wrap" Margin="0,12,0,0" /></StackPanel></Border></Grid>
                    <TextBlock x:Name="StatisticsCoverageText" Text="数据来源：Bridge 本地会话；不扫描 Microsoft 365 网页历史。" Foreground="{DynamicResource MutedTextBrush}" FontSize="11" TextWrapping="Wrap" Margin="0,14,0,0" />
                </StackPanel></ScrollViewer></Grid>
                <Grid x:Name="HistoryPanel" Visibility="Collapsed" Margin="40,28,40,36" MaxWidth="1120"><Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="*" /></Grid.RowDefinitions>
                    <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions><StackPanel><TextBlock Text="对话管理" Style="{StaticResource PageTitleStyle}" /><TextBlock Text="集中管理本地 Markdown 对话，并可显式导入当前打开的旧网页对话。" Foreground="{DynamicResource SubtleTextBrush}" Margin="0,6,0,0" /></StackPanel><Button x:Name="ImportConversationButton" Grid.Column="1" Content="导入对话" Style="{StaticResource PrimaryButtonStyle}" VerticalAlignment="Center" Click="ImportConversation_Click" /></Grid>
                    <Grid Grid.Row="1" Margin="0,26,0,0"><Grid.ColumnDefinitions><ColumnDefinition x:Name="HistoryProjectColumn" Width="230" /><ColumnDefinition x:Name="HistoryConversationColumn" Width="290" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                        <Border Style="{StaticResource CardStyle}" Margin="0,0,14,0">
                            <Grid>
                                <Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="*" /><RowDefinition Height="Auto" /></Grid.RowDefinitions>
                                <StackPanel Margin="16"><TextBlock Text="项目" Style="{StaticResource SectionTitleStyle}" /><TextBlock Text="拖动项目卡片排序；未分类对话的位置已锁定。" FontSize="12" Foreground="{DynamicResource SubtleTextBrush}" Margin="0,3,0,14" /><TextBlock Text="项目名称" FontSize="12" Foreground="{DynamicResource SubtleTextBrush}" Margin="0,0,0,5" /><TextBox x:Name="NewProjectTextBox" AutomationProperties.Name="项目名称" Margin="0,0,0,9" ToolTip="输入项目名称" /><Button x:Name="NewProjectButton" Content="创建项目" Style="{StaticResource SecondaryButtonStyle}" Click="NewProject_Click" /></StackPanel>
                                <ListBox x:Name="ProjectListBox" Grid.Row="1" Margin="10,0,10,10" BorderThickness="0" AutomationProperties.Name="项目列表" AutomationProperties.HelpText="按 Alt+上移或 Alt+下移调整所选项目顺序" SelectionChanged="Project_SelectionChanged" PreviewKeyDown="ProjectListBox_PreviewKeyDown" PreviewMouseLeftButtonDown="ProjectListBox_PreviewMouseLeftButtonDown" PreviewMouseMove="ProjectListBox_PreviewMouseMove" PreviewMouseRightButtonDown="ProjectListBox_PreviewMouseRightButtonDown" ContextMenuOpening="ProjectListBox_ContextMenuOpening" AllowDrop="True" PreviewDragOver="ProjectListBox_PreviewDragOver" DragLeave="DragListBox_DragLeave" Drop="ProjectListBox_Drop" ToolTip="拖动项目卡片排序，也可将会话拖入项目归类"><ListBox.ContextMenu><ContextMenu><MenuItem x:Name="PinProjectMenuItem" Header="置顶" Click="PinProjectMenuItem_Click" /><MenuItem x:Name="RenameProjectMenuItem" Header="重命名" Click="RenameProjectMenuItem_Click" /><MenuItem x:Name="DeleteProjectMenuItem" Header="删除" Click="DeleteProjectMenuItem_Click" /></ContextMenu></ListBox.ContextMenu><ListBox.ItemTemplate><DataTemplate><Border Background="{DynamicResource SoftSurfaceBrush}" BorderBrush="{DynamicResource LineBrush}" BorderThickness="1" CornerRadius="10" Padding="12,10" Margin="0,3"><DockPanel><TextBlock FontFamily="Segoe Fluent Icons" Foreground="{DynamicResource SubtleTextBrush}" Margin="0,0,10,0"><TextBlock.Style><Style TargetType="TextBlock"><Setter Property="Text" Value="&#xE8FD;" /><Setter Property="ToolTip" Value="拖动排序" /><Style.Triggers><DataTrigger Binding="{Binding IsSystem}" Value="True"><Setter Property="Text" Value="&#xE72E;" /><Setter Property="ToolTip" Value="位置已锁定" /></DataTrigger></Style.Triggers></Style></TextBlock.Style></TextBlock><TextBlock Text="{Binding Name}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" /><TextBlock DockPanel.Dock="Right" Text="&#xE840;" FontFamily="Segoe Fluent Icons" Foreground="{DynamicResource AccentTextBrush}" ToolTip="已置顶"><TextBlock.Style><Style TargetType="TextBlock"><Setter Property="Visibility" Value="Collapsed" /><Style.Triggers><DataTrigger Binding="{Binding IsPinned}" Value="True"><Setter Property="Visibility" Value="Visible" /></DataTrigger></Style.Triggers></Style></TextBlock.Style></TextBlock></DockPanel></Border></DataTemplate></ListBox.ItemTemplate></ListBox>
                                <Border Grid.Row="2" BorderBrush="{DynamicResource LineBrush}" BorderThickness="0,1,0,0" Padding="14,12"><StackPanel><TextBlock Text="Agent 访问权限" FontWeight="SemiBold" /><ComboBox x:Name="ProjectAccessComboBox" Margin="0,8,0,0"><ComboBoxItem Content="关闭（默认）" /><ComboBoxItem Content="仅元数据" /><ComboBoxItem Content="检索片段" /><ComboBoxItem Content="完整会话" /></ComboBox><Button x:Name="SaveProjectAccessButton" Content="保存访问权限" Style="{StaticResource SecondaryButtonStyle}" Margin="0,8,0,0" Click="SaveProjectAccess_Click" /><TextBlock Text="只控制本地 MCP 读取，不代表允许向 Copilot 发送。" TextWrapping="Wrap" FontSize="11" Foreground="{DynamicResource SubtleTextBrush}" Margin="0,8,0,0" /></StackPanel></Border>
                            </Grid>
                        </Border>
                        <Border Grid.Column="1" Style="{StaticResource CardStyle}" Margin="0,0,14,0"><Grid><Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="*" /></Grid.RowDefinitions><TextBlock Text="会话（可拖入项目）" FontWeight="SemiBold" Margin="16" /><ListBox x:Name="ConversationListBox" AutomationProperties.Name="会话列表" AutomationProperties.HelpText="普通点击选择会话；按住左侧拖拽手柄可将会话拖入项目" Grid.Row="1" Margin="10,0,10,10" BorderThickness="0" SelectionChanged="Conversation_SelectionChanged" PreviewMouseLeftButtonDown="ConversationListBox_PreviewMouseLeftButtonDown" PreviewMouseLeftButtonUp="ConversationListBox_PreviewMouseLeftButtonUp" PreviewMouseRightButtonDown="ConversationListBox_PreviewMouseRightButtonDown" PreviewMouseMove="ConversationListBox_PreviewMouseMove"><ListBox.ContextMenu><ContextMenu><MenuItem x:Name="RenameConversationMenuItem" Header="重命名" Click="RenameConversationMenuItem_Click" /><MenuItem x:Name="DeleteConversationMenuItem" Header="删除" Click="DeleteConversationMenuItem_Click" /></ContextMenu></ListBox.ContextMenu><ListBox.ItemTemplate><DataTemplate><Grid Margin="7"><Grid.ColumnDefinitions><ColumnDefinition Width="22" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions><Border Tag="ConversationDragHandle" Cursor="SizeAll" ToolTip="拖动到项目" Background="Transparent" Padding="0,2,6,2"><TextBlock Text="&#xE8FD;" FontFamily="Segoe Fluent Icons" Foreground="{DynamicResource SubtleTextBrush}" VerticalAlignment="Center" /></Border><StackPanel Grid.Column="1"><TextBlock Text="{Binding DisplayTitle}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" /><TextBlock Text="{Binding CopilotTitle}" Foreground="{DynamicResource SubtleTextBrush}" FontSize="11" TextTrimming="CharacterEllipsis" /><TextBlock Text="{Binding LastModel}" Foreground="{DynamicResource AccentTextBrush}" FontSize="11" Margin="0,3,0,0" /></StackPanel></Grid></DataTemplate></ListBox.ItemTemplate></ListBox></Grid></Border>
                        <Border Grid.Column="2" Style="{StaticResource CardStyle}"><Grid><Grid.RowDefinitions><RowDefinition Height="*" /></Grid.RowDefinitions><TextBlock x:Name="ConversationEmptyText" Text="选择或创建一个即时会话" Foreground="{DynamicResource SubtleTextBrush}" HorizontalAlignment="Center" VerticalAlignment="Center" /><ScrollViewer x:Name="ConversationDetailPanel" Visibility="Collapsed" VerticalScrollBarVisibility="Auto"><StackPanel Margin="24"><TextBlock Text="本地显示名称" FontSize="12" Foreground="{DynamicResource SubtleTextBrush}" Margin="0,0,0,5" /><Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions><TextBox x:Name="ConversationTitleTextBox" AutomationProperties.Name="本地显示名称" FontSize="21" FontWeight="SemiBold" BorderThickness="0" Padding="0" /><Button x:Name="RenameConversationButton" Grid.Column="1" Content="保存名称" Style="{StaticResource SecondaryButtonStyle}" Click="RenameConversation_Click" /></Grid>
                            <TextBlock x:Name="CopilotTitleText" Foreground="{DynamicResource SubtleTextBrush}" Margin="0,10,0,0" /><TextBlock x:Name="CopilotTitleHistoryText" Foreground="{DynamicResource SubtleTextBrush}" FontSize="12" Margin="0,3,0,0" /><TextBlock x:Name="ConversationMetaText" Foreground="{DynamicResource AccentTextBrush}" FontSize="12" Margin="0,8,0,0" />
                            <StackPanel Orientation="Horizontal" Margin="0,18,0,0"><TextBlock Text="移动到：" VerticalAlignment="Center" /><ComboBox x:Name="MoveProjectComboBox" AutomationProperties.Name="移动会话到项目" Width="170" DisplayMemberPath="Name" SelectedValuePath="Id" /><Button x:Name="MoveConversationButton" Content="移动" Style="{StaticResource SecondaryButtonStyle}" Margin="8,0,0,0" Click="MoveConversation_Click" /><Button Content="复制 Markdown" Style="{StaticResource SecondaryButtonStyle}" Margin="8,0,0,0" Click="CopyConversation_Click" /></StackPanel>
                            <Separator Margin="0,20" /><TextBlock Text="会话内检索" FontWeight="SemiBold" /><Grid Margin="0,8,0,0"><Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions><TextBox x:Name="ConversationSearchTextBox" AutomationProperties.Name="会话内检索关键词" /><Button Grid.Column="1" Content="检索" Style="{StaticResource SecondaryButtonStyle}" Margin="8,0,0,0" Click="SearchConversation_Click" /></Grid><TextBlock x:Name="SearchResultsText" TextWrapping="Wrap" Foreground="{DynamicResource SubtleTextBrush}" Margin="0,8,0,0" />
                            <Separator Margin="0,20" /><TextBlock Text="Markdown 对话" FontWeight="SemiBold" /><TextBox x:Name="ConversationMarkdownTextBox" Margin="0,8,0,0" IsReadOnly="True" AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" MinHeight="280" FontFamily="Cascadia Mono, Noto Sans SC, Consolas" FontSize="12" />
                        </StackPanel></ScrollViewer></Grid></Border>
                    </Grid>
                </Grid>
                <Grid x:Name="CollaborationPanel" Visibility="Collapsed"><ScrollViewer VerticalScrollBarVisibility="Auto"><StackPanel Margin="40,34,40,48" MaxWidth="920"><TextBlock Text="协作默认设置" Style="{StaticResource PageTitleStyle}" /><TextBlock Text="这里定义新会话的默认行为；即时会话记录会保存实际使用的模式和模型。" Style="{StaticResource PageDescriptionStyle}" />
                    <Border Style="{StaticResource CardStyle}" Padding="22"><StackPanel><TextBlock Text="征询策略" Style="{StaticResource SectionTitleStyle}" /><TextBlock Text="为新会话选择 Copilot 的介入方式。" Foreground="{DynamicResource SubtleTextBrush}" Margin="0,5,0,12" /><ComboBox x:Name="PolicyComboBox" Width="380" HorizontalAlignment="Left"><ComboBoxItem Content="关闭" /><ComboBoxItem Content="仅手动（默认）" /><ComboBoxItem Content="Codex 可自动征询" /><ComboBoxItem Content="关键设计必须征询" /></ComboBox></StackPanel></Border>
                      <Border Style="{StaticResource CardStyle}" Padding="22" Margin="0,16,0,0"><Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions><StackPanel><TextBlock Text="默认协作模式" Style="{StaticResource SectionTitleStyle}" /><RadioButton x:Name="AssistRadio" GroupName="CollaborationMode" IsChecked="True" Content="Assist — 快速聚焦的第二意见" Margin="0,14,0,0" /><RadioButton x:Name="OutsourceRadio" GroupName="CollaborationMode" Content="Outsource — 开放式推理" Margin="0,8,0,0" /><RadioButton x:Name="ReviewRadio" GroupName="CollaborationMode" Content="Review — 两个隔离 reviewer" Margin="0,8,0,0" /></StackPanel><Button x:Name="SaveCollaborationButton" Grid.Column="1" Content="保存协作默认设置" Style="{StaticResource PrimaryButtonStyle}" VerticalAlignment="Top" Margin="24,0,0,0" Click="Save_Click" /></Grid></Border>
                      <Border Style="{StaticResource CardStyle}" Padding="22" Margin="0,16,0,0"><StackPanel><TextBlock Text="协作模式设定" Style="{StaticResource SectionTitleStyle}" /><TextBlock Text="为新咨询设置模式轮次预算；创建后会固定在该咨询中。范围 1–20。" Foreground="{DynamicResource SubtleTextBrush}" TextWrapping="Wrap" Margin="0,6,0,16" /><Grid><Grid.ColumnDefinitions><ColumnDefinition Width="1*" /><ColumnDefinition Width="1*" /><ColumnDefinition Width="1*" /></Grid.ColumnDefinitions><StackPanel Margin="0,0,12,0"><TextBlock Text="Assist 最大轮次" Foreground="{DynamicResource SubtleTextBrush}" /><TextBox x:Name="AssistTurnBudgetTextBox" AutomationProperties.Name="Assist 最大轮次" Margin="0,7,0,0" /></StackPanel><StackPanel Grid.Column="1" Margin="6,0"><TextBlock Text="Outsource 最大轮次" Foreground="{DynamicResource SubtleTextBrush}" /><TextBox x:Name="OutsourceTurnBudgetTextBox" AutomationProperties.Name="Outsource 最大轮次" Margin="0,7,0,0" /></StackPanel><StackPanel Grid.Column="2" Margin="12,0,0,0"><TextBlock Text="Review 最大审查轮次" Foreground="{DynamicResource SubtleTextBrush}" /><TextBox x:Name="ReviewTurnBudgetTextBox" AutomationProperties.Name="Review 最大审查轮次" Margin="0,7,0,0" /></StackPanel></Grid><TextBlock Text="Review 每轮始终串行运行 complexity 与 evidence 两个隔离 reviewer。" Foreground="{DynamicResource SubtleTextBrush}" FontSize="12" TextWrapping="Wrap" Margin="0,12,0,0" /></StackPanel></Border>
                </StackPanel></ScrollViewer></Grid>
                <Grid x:Name="BrowserPanel" Visibility="Collapsed"><ScrollViewer VerticalScrollBarVisibility="Auto"><StackPanel Margin="40,34,40,48" MaxWidth="920"><TextBlock Text="浏览器与模型" Style="{StaticResource PageTitleStyle}" /><TextBlock Text="配置模型回退顺序、菜单等待与回复超时。" Style="{StaticResource PageDescriptionStyle}" />
                    <Border Style="{StaticResource CardStyle}" Padding="22"><StackPanel><TextBlock Text="模型优先级" Style="{StaticResource SectionTitleStyle}" /><TextBlock Text="拖动选项卡排序；仅在上方模型不可用时回退。" Foreground="{DynamicResource SubtleTextBrush}" Margin="0,6,0,10" /><ListBox x:Name="ModelPriorityListBox" AutomationProperties.Name="模型优先级列表" AutomationProperties.HelpText="按 Alt+上移或 Alt+下移调整所选模型顺序" BorderThickness="0" Background="Transparent" AllowDrop="True" PreviewKeyDown="ModelPriorityListBox_PreviewKeyDown" PreviewMouseLeftButtonDown="ModelPriorityListBox_PreviewMouseLeftButtonDown" PreviewMouseMove="ModelPriorityListBox_PreviewMouseMove" PreviewDragOver="ModelPriorityListBox_PreviewDragOver" DragLeave="DragListBox_DragLeave" Drop="ModelPriorityListBox_Drop"><ListBox.ItemTemplate><DataTemplate><Border Background="{DynamicResource SoftSurfaceBrush}" BorderBrush="{DynamicResource LineBrush}" BorderThickness="1" CornerRadius="10" Padding="14,11" Margin="0,4"><DockPanel><TextBlock Text="&#xE8FD;" FontFamily="Segoe Fluent Icons" Foreground="{DynamicResource SubtleTextBrush}" Margin="0,0,10,0" ToolTip="拖动排序" /><TextBlock Text="{Binding}" FontWeight="SemiBold" /></DockPanel></Border></DataTemplate></ListBox.ItemTemplate></ListBox></StackPanel></Border>
                    <Border Style="{StaticResource CardStyle}" Padding="22" Margin="0,16,0,0"><Grid><Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /></Grid.RowDefinitions><Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions><StackPanel><TextBlock Text="等待设置" Style="{StaticResource SectionTitleStyle}" /><TextBlock Text="协作模式轮次预算在“协作默认设置”中配置。" Foreground="{DynamicResource SubtleTextBrush}" Margin="0,6,0,0" /></StackPanel><Button x:Name="SaveBrowserButton" Grid.Column="1" Content="保存浏览器与模型设置" Style="{StaticResource PrimaryButtonStyle}" VerticalAlignment="Top" Margin="24,0,0,0" Click="Save_Click" /></Grid><Grid Grid.Row="1" Margin="0,18,0,0"><Grid.ColumnDefinitions><ColumnDefinition Width="220" /><ColumnDefinition Width="220" /><ColumnDefinition Width="220" /></Grid.ColumnDefinitions><StackPanel><TextBlock Text="菜单最短等待（ms）" Foreground="{DynamicResource SubtleTextBrush}" /><TextBox x:Name="MenuMinimumTextBox" Width="190" Margin="0,7,0,0" /></StackPanel><StackPanel Grid.Column="1"><TextBlock Text="菜单最大等待（ms）" Foreground="{DynamicResource SubtleTextBrush}" /><TextBox x:Name="MenuMaximumTextBox" Width="190" Margin="0,7,0,0" /></StackPanel><StackPanel Grid.Column="2"><TextBlock Text="回复超时（秒）" Foreground="{DynamicResource SubtleTextBrush}" /><TextBox x:Name="ReplyTimeoutTextBox" Width="190" Margin="0,7,0,0" /></StackPanel></Grid></Grid></Border>
                </StackPanel></ScrollViewer></Grid>
                <Grid x:Name="SettingsPanel" Visibility="Collapsed"><ScrollViewer VerticalScrollBarVisibility="Auto"><StackPanel Margin="40,34,40,48" MaxWidth="920">
                    <TextBlock Text="设置" Style="{StaticResource PageTitleStyle}" /><TextBlock Text="立即切换应用界面语言；该偏好会保存在本机设置中。" Style="{StaticResource PageDescriptionStyle}" />
                    <Border Style="{StaticResource CardStyle}" Padding="22"><StackPanel><TextBlock Text="外观与语言" Style="{StaticResource SectionTitleStyle}" /><Grid Margin="0,16,0,0"><Grid.ColumnDefinitions><ColumnDefinition Width="1*" /><ColumnDefinition Width="1*" /></Grid.ColumnDefinitions><StackPanel Margin="0,0,12,0"><TextBlock Text="显示语言" FontWeight="SemiBold" /><ComboBox x:Name="LanguageComboBox" HorizontalAlignment="Stretch" Margin="0,9,0,0" SelectionChanged="Language_SelectionChanged"><ComboBoxItem Content="中文" /><ComboBoxItem Content="English" /></ComboBox></StackPanel><StackPanel Grid.Column="1" Margin="12,0,0,0"><TextBlock Text="主题" FontWeight="SemiBold" /><ComboBox x:Name="ThemeComboBox" AutomationProperties.Name="主题" HorizontalAlignment="Stretch" Margin="0,9,0,0" SelectionChanged="Theme_SelectionChanged"><ComboBoxItem Content="浅色（默认）" /><ComboBoxItem Content="深色（Copilot）" /></ComboBox></StackPanel></Grid><TextBlock Text="深色主题采用 Microsoft Copilot 风格的低眩光中性画布。" Foreground="{DynamicResource SubtleTextBrush}" FontSize="12" Margin="0,12,0,0" /></StackPanel></Border>
                    <Border Style="{StaticResource CardStyle}" Padding="22" Margin="0,16,0,0"><StackPanel><TextBlock Text="后台常驻" Style="{StaticResource SectionTitleStyle}" /><CheckBox x:Name="KeepMcpRunningCheckBox" Style="{StaticResource ToggleSwitchStyle}" Content="关闭 GUI 后保持 MCP 后台进程" Margin="0,14,0,0" /><TextBlock Text="开启时，关闭 GUI 会询问是否终止 MCP；关闭时，关闭 GUI 会直接终止 Bridge 自己登记的 MCP 进程。" Foreground="{DynamicResource SubtleTextBrush}" TextWrapping="Wrap" Margin="0,10,0,0" /></StackPanel></Border>
                    <Border Style="{StaticResource CardStyle}" Padding="22" Margin="0,16,0,0"><StackPanel><TextBlock Text="系统托盘" Style="{StaticResource SectionTitleStyle}" /><CheckBox x:Name="UseSystemTrayCheckBox" Style="{StaticResource ToggleSwitchStyle}" Content="关闭窗口时隐藏到系统托盘" Margin="0,14,0,0" Click="UseSystemTray_Click" /><TextBlock Text="默认关闭。开关会立即保存；开启后，窗口关闭按钮只隐藏 GUI。双击托盘图标或选择“打开”可恢复，托盘菜单“退出”才真正关闭。" Foreground="{DynamicResource SubtleTextBrush}" TextWrapping="Wrap" Margin="0,10,0,0" /></StackPanel></Border>
                    <Border Style="{StaticResource CardStyle}" Padding="22" Margin="0,16,0,0"><StackPanel><TextBlock Text="快捷方式" Style="{StaticResource SectionTitleStyle}" /><TextBlock Text="选择 Copilot Bridge 的启动位置，并管理其启动方式。" Foreground="{DynamicResource SubtleTextBrush}" Margin="0,6,0,18" /><TextBlock Text="固定" FontWeight="SemiBold" Margin="0,0,0,10" /><Button x:Name="PinTaskbarButton" Style="{StaticResource ShortcutCardButtonStyle}" Click="PinTaskbar_Click"><StackPanel Orientation="Horizontal"><TextBlock Text="&#xE718;" FontFamily="Segoe Fluent Icons" FontSize="20" Width="34" VerticalAlignment="Center" /><TextBlock Text="固定到任务栏" FontSize="15" FontWeight="SemiBold" VerticalAlignment="Center" /></StackPanel></Button><Button x:Name="PinStartButton" Style="{StaticResource ShortcutCardButtonStyle}" Margin="0,10,0,0" Click="PinStart_Click"><StackPanel Orientation="Horizontal"><TextBlock Text="&#xE718;" FontFamily="Segoe Fluent Icons" FontSize="20" Width="34" VerticalAlignment="Center" /><TextBlock Text="固定到“开始”" FontSize="15" FontWeight="SemiBold" VerticalAlignment="Center" /></StackPanel></Button><Button x:Name="CreateDesktopShortcutButton" Style="{StaticResource ShortcutCardButtonStyle}" Margin="0,10,0,0" Click="CreateDesktopShortcut_Click"><StackPanel Orientation="Horizontal"><TextBlock Text="&#xE7F4;" FontFamily="Segoe Fluent Icons" FontSize="20" Width="34" VerticalAlignment="Center" /><TextBlock Text="创建桌面快捷方式" FontSize="15" FontWeight="SemiBold" VerticalAlignment="Center" /></StackPanel></Button></StackPanel></Border>
                    <Border Style="{StaticResource CardStyle}" Padding="22" Margin="0,16,0,0"><Grid><Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /></Grid.RowDefinitions><Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions><StackPanel><TextBlock Text="本地会话工作区" Style="{StaticResource SectionTitleStyle}" /><TextBlock Text="即时会话以一会话一 Markdown 文件保存在此处；旧网页历史不会自动导入。" Foreground="{DynamicResource SubtleTextBrush}" Margin="0,6,0,0" /></StackPanel><Button x:Name="SaveSettingsButton" Grid.Column="1" Content="保存设置" Style="{StaticResource PrimaryButtonStyle}" VerticalAlignment="Top" Margin="24,0,0,0" Click="Save_Click" /></Grid><Grid Grid.Row="1" Margin="0,16,0,0"><Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions><TextBox x:Name="WorkspaceDirectoryTextBox" /><Button x:Name="OpenWorkspaceButton" Grid.Column="1" Content="打开" Style="{StaticResource SecondaryButtonStyle}" Margin="10,0,0,0" Click="OpenWorkspace_Click" /><Button x:Name="BrowseWorkspaceButton" Grid.Column="2" Content="浏览" Style="{StaticResource SecondaryButtonStyle}" Margin="10,0,0,0" Click="BrowseWorkspace_Click" /></Grid></Grid></Border>
                    <Border Style="{StaticResource CardStyle}" Padding="22" Margin="0,16,0,0"><Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions><StackPanel><TextBlock Text="会话存储" Style="{StaticResource SectionTitleStyle}" /><TextBlock Text="新会话使用干净 Markdown 与分离元数据；旧格式只在你确认后迁移，并保留可回滚备份。" Foreground="{DynamicResource SubtleTextBrush}" TextWrapping="Wrap" Margin="0,6,24,0" /><TextBlock x:Name="StorageMigrationStatusText" Text="尚未检查旧格式会话。" Foreground="{DynamicResource AccentTextBrush}" Margin="0,10,24,0" /></StackPanel><StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Top"><Button x:Name="MigrateStorageButton" Content="迁移旧格式" Style="{StaticResource PrimaryButtonStyle}" Click="MigrateStorage_Click" /><Button x:Name="RollbackStorageButton" Content="回滚最近迁移" Style="{StaticResource SecondaryButtonStyle}" Margin="10,0,0,0" Click="RollbackStorage_Click" /></StackPanel></Grid></Border>
                </StackPanel></ScrollViewer></Grid>
            </Grid>
        </Grid>
    </Grid>
</Window>
