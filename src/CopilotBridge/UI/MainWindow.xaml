<Window x:Class="CopilotBridge.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Copilot Bridge" Width="1320" Height="800" MinWidth="1040" MinHeight="680"
        WindowStartupLocation="CenterScreen" Background="#F5F6F8"
        FontFamily="Segoe UI Variable Text, Segoe UI" Foreground="#1D232F" Loaded="Window_Loaded">
    <Window.Resources>
        <SolidColorBrush x:Key="AccentBrush" Color="#0A6CFF" />
        <SolidColorBrush x:Key="SubtleTextBrush" Color="#697586" />
        <SolidColorBrush x:Key="LineBrush" Color="#E4E7EC" />
        <Style x:Key="NavButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="46" /><Setter Property="Margin" Value="10,3" />
            <Setter Property="Padding" Value="14,0" /><Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="Background" Value="Transparent" /><Setter Property="Foreground" Value="#4D5868" />
            <Setter Property="BorderThickness" Value="0" /><Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template"><Setter.Value><ControlTemplate TargetType="Button">
                <Border x:Name="Border" Background="{TemplateBinding Background}" CornerRadius="8">
                    <ContentPresenter Margin="{TemplateBinding Padding}" VerticalAlignment="Center" HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" />
                </Border>
                <ControlTemplate.Triggers><Trigger Property="IsMouseOver" Value="True"><Setter TargetName="Border" Property="Background" Value="#EDF0F4" /></Trigger></ControlTemplate.Triggers>
            </ControlTemplate></Setter.Value></Setter>
        </Style>
        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="38" /><Setter Property="Padding" Value="18,0" />
            <Setter Property="Background" Value="{StaticResource AccentBrush}" /><Setter Property="Foreground" Value="White" />
            <Setter Property="BorderThickness" Value="0" /><Setter Property="FontWeight" Value="SemiBold" /><Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template"><Setter.Value><ControlTemplate TargetType="Button">
                <Border x:Name="Border" Background="{TemplateBinding Background}" CornerRadius="7"><ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" /></Border>
                <ControlTemplate.Triggers><Trigger Property="IsMouseOver" Value="True"><Setter TargetName="Border" Property="Opacity" Value="0.88" /></Trigger><Trigger Property="IsEnabled" Value="False"><Setter TargetName="Border" Property="Opacity" Value="0.45" /></Trigger></ControlTemplate.Triggers>
            </ControlTemplate></Setter.Value></Setter>
        </Style>
        <Style x:Key="SecondaryButtonStyle" TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
            <Setter Property="Background" Value="White" /><Setter Property="Foreground" Value="#344054" /><Setter Property="BorderBrush" Value="{StaticResource LineBrush}" /><Setter Property="BorderThickness" Value="1" />
        </Style>
        <Style TargetType="TextBox"><Setter Property="Padding" Value="10,7" /><Setter Property="BorderBrush" Value="#D7DCE3" /><Setter Property="BorderThickness" Value="1" /><Setter Property="Background" Value="White" /></Style>
        <Style TargetType="ComboBox"><Setter Property="Padding" Value="8,5" /><Setter Property="BorderBrush" Value="#D7DCE3" /><Setter Property="BorderThickness" Value="1" /></Style>
    </Window.Resources>
    <Grid>
        <Grid.ColumnDefinitions><ColumnDefinition Width="238" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
        <Border Grid.Column="0" Background="White" BorderBrush="#E4E7EC" BorderThickness="0,0,1,0">
            <Grid><Grid.RowDefinitions><RowDefinition Height="78" /><RowDefinition Height="*" /><RowDefinition Height="Auto" /></Grid.RowDefinitions>
                <StackPanel Orientation="Horizontal" Margin="20,22"><Border Width="32" Height="32" Background="#0A6CFF" CornerRadius="8"><TextBlock Text="&#xE71B;" FontFamily="Segoe Fluent Icons" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" /></Border><StackPanel Margin="10,0"><TextBlock Text="Copilot Bridge" FontSize="17" FontWeight="SemiBold" /><TextBlock Text="v1.1 会话工作台" FontSize="11" Foreground="{StaticResource SubtleTextBrush}" /></StackPanel></StackPanel>
                <StackPanel Grid.Row="1" Margin="0,10">
                    <Button x:Name="OverviewNav" Style="{StaticResource NavButtonStyle}" Tag="overview" Click="Navigation_Click"><StackPanel Orientation="Horizontal"><TextBlock Text="&#xE80F;" FontFamily="Segoe Fluent Icons" Width="30" /><TextBlock Text="概览" /></StackPanel></Button>
                    <Button x:Name="HistoryNav" Style="{StaticResource NavButtonStyle}" Tag="history" Click="Navigation_Click"><StackPanel Orientation="Horizontal"><TextBlock Text="&#xE81C;" FontFamily="Segoe Fluent Icons" Width="30" /><TextBlock Text="历史对话" /></StackPanel></Button>
                    <Button x:Name="CollaborationNav" Style="{StaticResource NavButtonStyle}" Tag="collaboration" Click="Navigation_Click"><StackPanel Orientation="Horizontal"><TextBlock Text="&#xE902;" FontFamily="Segoe Fluent Icons" Width="30" /><TextBlock Text="协作默认设置" /></StackPanel></Button>
                    <Button x:Name="BrowserNav" Style="{StaticResource NavButtonStyle}" Tag="browser" Click="Navigation_Click"><StackPanel Orientation="Horizontal"><TextBlock Text="&#xE774;" FontFamily="Segoe Fluent Icons" Width="30" /><TextBlock Text="浏览器与模型" /></StackPanel></Button>
                    <Button x:Name="SettingsNav" Style="{StaticResource NavButtonStyle}" Tag="settings" Click="Navigation_Click"><StackPanel Orientation="Horizontal"><TextBlock Text="&#xE713;" FontFamily="Segoe Fluent Icons" Width="30" /><TextBlock Text="设置" /></StackPanel></Button>
                </StackPanel>
                <StackPanel Grid.Row="2" Margin="20,18"><Separator Background="{StaticResource LineBrush}" /><TextBlock Text="数据保存在你的本地工作区" FontSize="11" Foreground="#9AA3AF" Margin="0,12,0,0" /></StackPanel>
            </Grid>
        </Border>
        <Grid Grid.Column="1"><Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="*" /></Grid.RowDefinitions>
            <Grid Margin="32,18,32,0"><Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions><TextBlock x:Name="HeaderStatusText" Text="正在初始化" Foreground="{StaticResource SubtleTextBrush}" VerticalAlignment="Center" /><ProgressBar x:Name="BusyProgress" Grid.Column="1" Width="130" Height="4" IsIndeterminate="True" Visibility="Collapsed" /></Grid>
            <Border x:Name="NoticeBorder" Grid.Row="0" Margin="32,44,32,0" Padding="14,10" Background="#FFF4E5" BorderBrush="#FFD7A3" BorderThickness="1" CornerRadius="7" Visibility="Collapsed"><TextBlock x:Name="NoticeText" TextWrapping="Wrap" Foreground="#7A4A0A" /></Border>
            <Grid Grid.Row="1">
                <Grid x:Name="OverviewPanel"><ScrollViewer VerticalScrollBarVisibility="Auto"><StackPanel Margin="36,28,36,40" MaxWidth="1040">
                    <TextBlock Text="概览" FontSize="28" FontWeight="SemiBold" /><TextBlock Text="检查后台连接，并将新产生的即时咨询完整写入本地 Markdown 会话。" Foreground="{StaticResource SubtleTextBrush}" Margin="0,7,0,24" />
                    <Border Background="White" BorderBrush="{StaticResource LineBrush}" BorderThickness="1" CornerRadius="10"><Grid><Grid.RowDefinitions><RowDefinition Height="54" /><RowDefinition Height="54" /><RowDefinition Height="54" /><RowDefinition Height="54" /></Grid.RowDefinitions><Grid.ColumnDefinitions><ColumnDefinition Width="180" /><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                        <TextBlock Text="Edge 连接" Margin="20,0" VerticalAlignment="Center" Foreground="{StaticResource SubtleTextBrush}" /><TextBlock x:Name="EdgeStatusText" Grid.Column="1" VerticalAlignment="Center" FontWeight="SemiBold" Text="尚未检查" /><Ellipse x:Name="EdgeStatusDot" Grid.Column="2" Width="9" Height="9" Fill="#A8B0BC" Margin="20" />
                        <TextBlock Grid.Row="1" Text="专用标签页" Margin="20,0" VerticalAlignment="Center" Foreground="{StaticResource SubtleTextBrush}" /><TextBlock x:Name="TabStatusText" Grid.Row="1" Grid.Column="1" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" Text="未绑定" />
                        <TextBlock Grid.Row="2" Text="Microsoft 365 登录" Margin="20,0" VerticalAlignment="Center" Foreground="{StaticResource SubtleTextBrush}" /><TextBlock x:Name="LoginStatusText" Grid.Row="2" Grid.Column="1" VerticalAlignment="Center" Text="未知" />
                        <TextBlock Grid.Row="3" Text="页面当前模型" Margin="20,0" VerticalAlignment="Center" Foreground="{StaticResource SubtleTextBrush}" /><TextBlock x:Name="ModelStatusText" Grid.Row="3" Grid.Column="1" VerticalAlignment="Center" Text="未知" />
                    </Grid></Border>
                    <StackPanel Orientation="Horizontal" Margin="0,14,0,4"><Button x:Name="RefreshButton" Content="刷新状态" Style="{StaticResource SecondaryButtonStyle}" Click="Refresh_Click" /><Button x:Name="BindButton" Content="绑定当前 Copilot 标签页" Style="{StaticResource PrimaryButtonStyle}" Click="Bind_Click" Margin="10,0,0,0" /></StackPanel>
                    <TextBlock x:Name="AutoRefreshStatusText" Text="自动刷新正在准备。" Foreground="{StaticResource SubtleTextBrush}" FontSize="12" Margin="0,0,0,30" />
                    <TextBlock Text="即时咨询" FontSize="18" FontWeight="SemiBold" /><TextBlock Text="发送后会保存发送内容、Copilot 回复和已验证的实际模型；不会自动导入旧网页历史。" Foreground="{StaticResource SubtleTextBrush}" Margin="0,6,0,12" />
                    <TextBox x:Name="TestPromptTextBox" Height="120" AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" Text="这是 Copilot Bridge v1.1 即时会话测试。请只回复：COPILOT_BRIDGE_V11_OK" />
                    <Button x:Name="TestButton" Content="发送并记录即时咨询" Style="{StaticResource PrimaryButtonStyle}" HorizontalAlignment="Left" Margin="0,12,0,0" Click="Test_Click" />
                </StackPanel></ScrollViewer></Grid>
                <Grid x:Name="HistoryPanel" Visibility="Collapsed" Margin="28,20,28,28"><Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="*" /></Grid.RowDefinitions>
                    <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions><StackPanel><TextBlock Text="历史对话" FontSize="28" FontWeight="SemiBold" /><TextBlock Text="Bridge 管理的新即时对话会保留完整 Markdown；网页旧历史需在后续版本显式导入。" Foreground="{StaticResource SubtleTextBrush}" Margin="0,6,0,0" /></StackPanel><Button x:Name="NewConversationButton" Grid.Column="1" Content="+ 新建即时对话" Style="{StaticResource PrimaryButtonStyle}" VerticalAlignment="Center" Click="NewConversation_Click" /></Grid>
                    <Grid Grid.Row="1" Margin="0,22,0,0"><Grid.ColumnDefinitions><ColumnDefinition Width="220" /><ColumnDefinition Width="280" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                        <Border Background="White" BorderBrush="{StaticResource LineBrush}" BorderThickness="1" CornerRadius="10" Margin="0,0,12,0"><Grid><Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="*" /></Grid.RowDefinitions><StackPanel Margin="14"><TextBlock Text="项目与分类" FontWeight="SemiBold" /><TextBox x:Name="NewProjectTextBox" Margin="0,10,0,8" ToolTip="输入项目名称" /><Button x:Name="NewProjectButton" Content="创建项目" Style="{StaticResource SecondaryButtonStyle}" Click="NewProject_Click" /></StackPanel><ListBox x:Name="ProjectListBox" Grid.Row="1" Margin="8,0,8,8" BorderThickness="0" DisplayMemberPath="Name" SelectionChanged="Project_SelectionChanged" AllowDrop="True" Drop="ProjectListBox_Drop" ToolTip="可将会话拖到项目中归类" /></Grid></Border>
                        <Border Grid.Column="1" Background="White" BorderBrush="{StaticResource LineBrush}" BorderThickness="1" CornerRadius="10" Margin="0,0,12,0"><Grid><Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="*" /></Grid.RowDefinitions><TextBlock Text="会话（可拖入项目）" FontWeight="SemiBold" Margin="14" /><ListBox x:Name="ConversationListBox" Grid.Row="1" Margin="8,0,8,8" BorderThickness="0" SelectionChanged="Conversation_SelectionChanged" PreviewMouseLeftButtonDown="ConversationListBox_PreviewMouseLeftButtonDown" PreviewMouseMove="ConversationListBox_PreviewMouseMove"><ListBox.ItemTemplate><DataTemplate><StackPanel Margin="6"><TextBlock Text="{Binding DisplayTitle}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" /><TextBlock Text="{Binding CopilotTitle}" Foreground="{StaticResource SubtleTextBrush}" FontSize="11" TextTrimming="CharacterEllipsis" /><TextBlock Text="{Binding LastModel}" Foreground="#0A6CFF" FontSize="11" Margin="0,3,0,0" /></StackPanel></DataTemplate></ListBox.ItemTemplate></ListBox></Grid></Border>
                        <Border Grid.Column="2" Background="White" BorderBrush="{StaticResource LineBrush}" BorderThickness="1" CornerRadius="10"><Grid><Grid.RowDefinitions><RowDefinition Height="*" /></Grid.RowDefinitions><TextBlock x:Name="ConversationEmptyText" Text="选择或创建一个即时会话" Foreground="{StaticResource SubtleTextBrush}" HorizontalAlignment="Center" VerticalAlignment="Center" /><ScrollViewer x:Name="ConversationDetailPanel" Visibility="Collapsed" VerticalScrollBarVisibility="Auto"><StackPanel Margin="22"><Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions><TextBox x:Name="ConversationTitleTextBox" FontSize="21" FontWeight="SemiBold" BorderThickness="0" Padding="0" /><Button Grid.Column="1" Content="保存名称" Style="{StaticResource SecondaryButtonStyle}" Click="RenameConversation_Click" /></Grid>
                            <TextBlock x:Name="CopilotTitleText" Foreground="{StaticResource SubtleTextBrush}" Margin="0,10,0,0" /><TextBlock x:Name="CopilotTitleHistoryText" Foreground="#98A2B3" FontSize="11" Margin="0,3,0,0" /><TextBlock x:Name="ConversationMetaText" Foreground="#0A6CFF" FontSize="12" Margin="0,8,0,0" />
                            <StackPanel Orientation="Horizontal" Margin="0,18,0,0"><TextBlock Text="移动到：" VerticalAlignment="Center" /><ComboBox x:Name="MoveProjectComboBox" Width="170" DisplayMemberPath="Name" SelectedValuePath="Id" /><Button Content="移动" Style="{StaticResource SecondaryButtonStyle}" Margin="8,0,0,0" Click="MoveConversation_Click" /><Button Content="复制 Markdown" Style="{StaticResource SecondaryButtonStyle}" Margin="8,0,0,0" Click="CopyConversation_Click" /></StackPanel>
                            <Separator Margin="0,20" /><TextBlock Text="会话内检索" FontWeight="SemiBold" /><Grid Margin="0,8,0,0"><Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions><TextBox x:Name="ConversationSearchTextBox" /><Button Grid.Column="1" Content="检索" Style="{StaticResource SecondaryButtonStyle}" Margin="8,0,0,0" Click="SearchConversation_Click" /></Grid><TextBlock x:Name="SearchResultsText" TextWrapping="Wrap" Foreground="{StaticResource SubtleTextBrush}" Margin="0,8,0,0" />
                            <Separator Margin="0,20" /><TextBlock Text="Markdown 对话" FontWeight="SemiBold" /><TextBox x:Name="ConversationMarkdownTextBox" Margin="0,8,0,0" IsReadOnly="True" AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" MinHeight="280" FontFamily="Cascadia Mono, Consolas" FontSize="12" />
                        </StackPanel></ScrollViewer></Grid></Border>
                    </Grid>
                </Grid>
                <Grid x:Name="CollaborationPanel" Visibility="Collapsed"><ScrollViewer VerticalScrollBarVisibility="Auto"><StackPanel Margin="36,28,36,40" MaxWidth="900"><TextBlock Text="协作默认设置" FontSize="28" FontWeight="SemiBold" /><TextBlock Text="这里定义新会话的默认行为；即时会话记录会保存实际使用的模式和模型。" Foreground="{StaticResource SubtleTextBrush}" Margin="0,7,0,26" />
                    <TextBlock Text="征询策略" FontSize="16" FontWeight="SemiBold" /><ComboBox x:Name="PolicyComboBox" Width="360" HorizontalAlignment="Left" Margin="0,10,0,0"><ComboBoxItem Content="关闭" /><ComboBoxItem Content="仅手动（默认）" /><ComboBoxItem Content="Codex 可自动征询" /><ComboBoxItem Content="关键设计必须征询" /></ComboBox>
                    <Separator Margin="0,28" /><TextBlock Text="默认协作模式" FontSize="16" FontWeight="SemiBold" /><RadioButton x:Name="AssistRadio" GroupName="CollaborationMode" IsChecked="True" Content="Assist — 快速聚焦的第二意见" Margin="0,12,0,0" /><RadioButton x:Name="OutsourceRadio" GroupName="CollaborationMode" Content="Outsource — 有限回合的开放式推理" Margin="0,10,0,0" /><RadioButton x:Name="ReviewRadio" GroupName="CollaborationMode" Content="Review — 两个隔离 reviewer" Margin="0,10,0,0" /><Button x:Name="SaveCollaborationButton" Content="保存协作默认设置" Style="{StaticResource PrimaryButtonStyle}" HorizontalAlignment="Left" Margin="0,24,0,0" Click="Save_Click" />
                </StackPanel></ScrollViewer></Grid>
                <Grid x:Name="BrowserPanel" Visibility="Collapsed"><ScrollViewer VerticalScrollBarVisibility="Auto"><StackPanel Margin="36,28,36,40" MaxWidth="900"><TextBlock Text="浏览器、模型与本地工作区" FontSize="28" FontWeight="SemiBold" /><TextBlock Text="模型队列是默认回退策略；会话正文仅写入你选择的本地工作区。" Foreground="{StaticResource SubtleTextBrush}" Margin="0,7,0,26" />
                    <TextBlock Text="标签页绑定" FontSize="16" FontWeight="SemiBold" /><Border Background="White" BorderBrush="{StaticResource LineBrush}" BorderThickness="1" CornerRadius="9" Margin="0,12,0,0" Padding="18,15"><Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions><StackPanel><TextBlock Text="当前绑定" Foreground="{StaticResource SubtleTextBrush}" FontSize="12" /><TextBlock x:Name="BoundUrlText" Text="未绑定" Margin="0,6,20,0" TextTrimming="CharacterEllipsis" /></StackPanel><Button Grid.Column="1" Content="重新绑定" Style="{StaticResource SecondaryButtonStyle}" Click="Bind_Click" /></Grid></Border>
                    <Separator Margin="0,28" /><TextBlock Text="本地会话工作区" FontSize="16" FontWeight="SemiBold" /><TextBlock Text="即时会话以一会话一 Markdown 文件保存在此处；旧网页历史不会自动导入。" Foreground="{StaticResource SubtleTextBrush}" Margin="0,6,0,10" /><TextBox x:Name="WorkspaceDirectoryTextBox" />
                    <Separator Margin="0,28" /><TextBlock Text="模型优先级" FontSize="16" FontWeight="SemiBold" /><TextBlock Text="Opus → GPT 5.6 Think deeper → 深度思考。仅在高优先级不可用时回退。" Foreground="{StaticResource SubtleTextBrush}" Margin="0,6,0,12" />
                    <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="220" /><ColumnDefinition Width="220" /><ColumnDefinition Width="220" /></Grid.ColumnDefinitions><StackPanel><TextBlock Text="菜单最短等待（ms）" Foreground="{StaticResource SubtleTextBrush}" /><TextBox x:Name="MenuMinimumTextBox" Width="190" Margin="0,7,0,0" /></StackPanel><StackPanel Grid.Column="1"><TextBlock Text="菜单最大等待（ms）" Foreground="{StaticResource SubtleTextBrush}" /><TextBox x:Name="MenuMaximumTextBox" Width="190" Margin="0,7,0,0" /></StackPanel><StackPanel Grid.Column="2"><TextBlock Text="回复超时（秒）" Foreground="{StaticResource SubtleTextBrush}" /><TextBox x:Name="ReplyTimeoutTextBox" Width="190" Margin="0,7,0,0" /></StackPanel></Grid>
                    <Button x:Name="SaveBrowserButton" Content="保存浏览器与工作区设置" Style="{StaticResource PrimaryButtonStyle}" HorizontalAlignment="Left" Margin="0,24,0,0" Click="Save_Click" />
                </StackPanel></ScrollViewer></Grid>
                <Grid x:Name="SettingsPanel" Visibility="Collapsed"><ScrollViewer VerticalScrollBarVisibility="Auto"><StackPanel Margin="36,28,36,40" MaxWidth="900">
                    <TextBlock Text="设置" FontSize="28" FontWeight="SemiBold" /><TextBlock Text="立即切换应用界面语言；该偏好会保存在本机设置中。" Foreground="{StaticResource SubtleTextBrush}" Margin="0,7,0,26" />
                    <TextBlock Text="显示语言" FontSize="16" FontWeight="SemiBold" /><ComboBox x:Name="LanguageComboBox" Width="280" HorizontalAlignment="Left" Margin="0,10,0,0" SelectionChanged="Language_SelectionChanged"><ComboBoxItem Content="中文" /><ComboBoxItem Content="English" /></ComboBox>
                    <Button x:Name="SaveSettingsButton" Content="保存设置" Style="{StaticResource PrimaryButtonStyle}" HorizontalAlignment="Left" Margin="0,24,0,0" Click="Save_Click" />
                </StackPanel></ScrollViewer></Grid>
            </Grid>
        </Grid>
    </Grid>
</Window>
