<Window x:Class="CopilotBridge.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Copilot Bridge" Width="1320" Height="800" MinWidth="1040" MinHeight="680"
        WindowStartupLocation="CenterScreen" Background="{DynamicResource CanvasBrush}"
        FontFamily="Segoe UI Variable Text, Segoe UI" Foreground="{DynamicResource TextPrimaryBrush}" Loaded="Window_Loaded">
    <Window.Resources>
        <SolidColorBrush x:Key="CanvasBrush" Color="#F5F6F8" />
        <SolidColorBrush x:Key="SurfaceBrush" Color="#FFFFFF" />
        <SolidColorBrush x:Key="TextPrimaryBrush" Color="#1D232F" />
        <SolidColorBrush x:Key="AccentBrush" Color="#0A6CFF" />
        <SolidColorBrush x:Key="AccentTextBrush" Color="#0A6CFF" />
        <SolidColorBrush x:Key="OnAccentBrush" Color="#FFFFFF" />
        <SolidColorBrush x:Key="SubtleTextBrush" Color="#667085" />
        <SolidColorBrush x:Key="MutedTextBrush" Color="#667085" />
        <SolidColorBrush x:Key="LineBrush" Color="#E4E7EC" />
        <SolidColorBrush x:Key="ControlBorderBrush" Color="#D7DCE3" />
        <SolidColorBrush x:Key="NavTextBrush" Color="#4D5868" />
        <SolidColorBrush x:Key="NavHoverBrush" Color="#EDF0F4" />
        <SolidColorBrush x:Key="NavSelectedBrush" Color="#EAF3FF" />
        <SolidColorBrush x:Key="NavSelectedTextBrush" Color="#0A6CFF" />
        <SolidColorBrush x:Key="SecondaryActionBrush" Color="#344054" />
        <SolidColorBrush x:Key="StatusUnknownBrush" Color="#A8B0BC" />
        <SolidColorBrush x:Key="NoticeInfoBackgroundBrush" Color="#FFF4E5" />
        <SolidColorBrush x:Key="NoticeInfoBorderBrush" Color="#FFD7A3" />
        <SolidColorBrush x:Key="NoticeInfoTextBrush" Color="#7A4A0A" />
        <SolidColorBrush x:Key="NoticeSuccessBackgroundBrush" Color="#EAF7EF" />
        <SolidColorBrush x:Key="NoticeSuccessBorderBrush" Color="#B9E5C9" />
        <SolidColorBrush x:Key="NoticeSuccessTextBrush" Color="#176B3A" />
        <SolidColorBrush x:Key="NoticeErrorBackgroundBrush" Color="#FFF0F0" />
        <SolidColorBrush x:Key="NoticeErrorBorderBrush" Color="#F3C0C0" />
        <SolidColorBrush x:Key="NoticeErrorTextBrush" Color="#9B2C2C" />
        <Style x:Key="NavButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="46" /><Setter Property="Margin" Value="10,3" />
            <Setter Property="Padding" Value="14,0" /><Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="Background" Value="Transparent" /><Setter Property="Foreground" Value="{DynamicResource NavTextBrush}" />
            <Setter Property="BorderThickness" Value="0" /><Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template"><Setter.Value><ControlTemplate TargetType="Button">
                <Border x:Name="Border" Background="{TemplateBinding Background}" CornerRadius="8">
                    <ContentPresenter Margin="{TemplateBinding Padding}" VerticalAlignment="Center" HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" />
                </Border>
                <ControlTemplate.Triggers><Trigger Property="IsMouseOver" Value="True"><Setter TargetName="Border" Property="Background" Value="{DynamicResource NavHoverBrush}" /></Trigger></ControlTemplate.Triggers>
            </ControlTemplate></Setter.Value></Setter>
        </Style>
        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="38" /><Setter Property="Padding" Value="18,0" />
            <Setter Property="Background" Value="{DynamicResource AccentBrush}" /><Setter Property="Foreground" Value="{DynamicResource OnAccentBrush}" />
            <Setter Property="BorderThickness" Value="0" /><Setter Property="FontWeight" Value="SemiBold" /><Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template"><Setter.Value><ControlTemplate TargetType="Button">
                <Border x:Name="Border" Background="{TemplateBinding Background}" CornerRadius="7"><ContentPresenter Margin="{TemplateBinding Padding}" HorizontalAlignment="Center" VerticalAlignment="Center" /></Border>
                <ControlTemplate.Triggers><Trigger Property="IsMouseOver" Value="True"><Setter TargetName="Border" Property="Opacity" Value="0.88" /></Trigger><Trigger Property="IsEnabled" Value="False"><Setter TargetName="Border" Property="Opacity" Value="0.45" /></Trigger></ControlTemplate.Triggers>
            </ControlTemplate></Setter.Value></Setter>
        </Style>
        <Style x:Key="SecondaryButtonStyle" TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
            <Setter Property="Background" Value="{DynamicResource SurfaceBrush}" /><Setter Property="Foreground" Value="{DynamicResource SecondaryActionBrush}" /><Setter Property="BorderBrush" Value="{DynamicResource LineBrush}" /><Setter Property="BorderThickness" Value="1" />
        </Style>
        <Style TargetType="TextBox"><Setter Property="Padding" Value="10,7" /><Setter Property="BorderBrush" Value="{DynamicResource ControlBorderBrush}" /><Setter Property="BorderThickness" Value="1" /><Setter Property="Background" Value="{DynamicResource SurfaceBrush}" /><Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" /><Setter Property="CaretBrush" Value="{DynamicResource TextPrimaryBrush}" /></Style>
        <Style TargetType="ComboBox">
            <Setter Property="Padding" Value="10,6" /><Setter Property="BorderBrush" Value="{DynamicResource ControlBorderBrush}" /><Setter Property="BorderThickness" Value="1" />
            <Setter Property="Background" Value="{DynamicResource SurfaceBrush}" /><Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
            <Setter Property="Template"><Setter.Value><ControlTemplate TargetType="ComboBox">
                <Grid x:Name="Root" SnapsToDevicePixels="True">
                    <ToggleButton x:Name="ToggleButton" Focusable="False" ClickMode="Press" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" Foreground="{TemplateBinding Foreground}" IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}">
                        <ToggleButton.Template><ControlTemplate TargetType="ToggleButton"><Border x:Name="ToggleBorder" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="5"><Grid><ContentPresenter Margin="{TemplateBinding Padding}" VerticalAlignment="Center" HorizontalAlignment="Left" Content="{Binding SelectionBoxItem, RelativeSource={RelativeSource AncestorType=ComboBox}}" ContentTemplate="{Binding SelectionBoxItemTemplate, RelativeSource={RelativeSource AncestorType=ComboBox}}" ContentTemplateSelector="{Binding ItemTemplateSelector, RelativeSource={RelativeSource AncestorType=ComboBox}}" /><Path Data="M 0 0 L 5 5 L 10 0 Z" Fill="{TemplateBinding Foreground}" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="8" /></Grid></Border><ControlTemplate.Triggers><Trigger Property="IsMouseOver" Value="True"><Setter TargetName="ToggleBorder" Property="Background" Value="{DynamicResource NavHoverBrush}" /></Trigger><Trigger Property="IsChecked" Value="True"><Setter TargetName="ToggleBorder" Property="BorderBrush" Value="{DynamicResource AccentBrush}" /></Trigger></ControlTemplate.Triggers></ControlTemplate></ToggleButton.Template>
                    </ToggleButton>
                    <Popup x:Name="Popup" IsOpen="{TemplateBinding IsDropDownOpen}" Placement="Bottom" AllowsTransparency="True" PopupAnimation="Fade" Focusable="False">
                        <Border MinWidth="{Binding ActualWidth, ElementName=Root}" Margin="0,3,0,0" Background="{Binding Background, ElementName=Root}" BorderBrush="{Binding BorderBrush, ElementName=Root}" BorderThickness="1" CornerRadius="5">
                            <ScrollViewer Padding="2" MaxHeight="{TemplateBinding MaxDropDownHeight}" CanContentScroll="True"><ItemsPresenter /></ScrollViewer>
                        </Border>
                    </Popup>
                </Grid>
                <ControlTemplate.Triggers><Trigger Property="IsEnabled" Value="False"><Setter TargetName="Root" Property="Opacity" Value="0.5" /></Trigger><Trigger Property="IsKeyboardFocusWithin" Value="True"><Setter TargetName="ToggleButton" Property="BorderBrush" Value="{DynamicResource AccentBrush}" /></Trigger></ControlTemplate.Triggers>
            </ControlTemplate></Setter.Value></Setter>
        </Style>
        <Style TargetType="ComboBoxItem">
            <Setter Property="Padding" Value="10,6" /><Setter Property="HorizontalContentAlignment" Value="Stretch" /><Setter Property="Background" Value="{DynamicResource SurfaceBrush}" /><Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
            <Setter Property="Template"><Setter.Value><ControlTemplate TargetType="ComboBoxItem"><Border x:Name="ItemBorder" Background="{TemplateBinding Background}" CornerRadius="3"><ContentPresenter Margin="{TemplateBinding Padding}" HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" VerticalAlignment="Center" /></Border><ControlTemplate.Triggers><Trigger Property="IsHighlighted" Value="True"><Setter TargetName="ItemBorder" Property="Background" Value="{DynamicResource NavHoverBrush}" /></Trigger><Trigger Property="IsSelected" Value="True"><Setter TargetName="ItemBorder" Property="Background" Value="{DynamicResource NavSelectedBrush}" /><Setter Property="Foreground" Value="{DynamicResource NavSelectedTextBrush}" /></Trigger><Trigger Property="IsEnabled" Value="False"><Setter TargetName="ItemBorder" Property="Opacity" Value="0.5" /></Trigger></ControlTemplate.Triggers></ControlTemplate></Setter.Value></Setter>
        </Style>
        <Style TargetType="ListBox">
            <Setter Property="Padding" Value="4" /><Setter Property="Background" Value="{DynamicResource SurfaceBrush}" /><Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource LineBrush}" /><Setter Property="BorderThickness" Value="1" />
            <Setter Property="Template"><Setter.Value><ControlTemplate TargetType="ListBox"><Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="5"><ScrollViewer Padding="{TemplateBinding Padding}" Focusable="False"><ItemsPresenter /></ScrollViewer></Border></ControlTemplate></Setter.Value></Setter>
        </Style>
        <Style TargetType="ListBoxItem">
            <Setter Property="Padding" Value="8,6" /><Setter Property="HorizontalContentAlignment" Value="Stretch" /><Setter Property="Background" Value="Transparent" /><Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
            <Setter Property="Template"><Setter.Value><ControlTemplate TargetType="ListBoxItem"><Border x:Name="ItemBorder" Background="{TemplateBinding Background}" CornerRadius="4"><ContentPresenter Margin="{TemplateBinding Padding}" HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" VerticalAlignment="Center" /></Border><ControlTemplate.Triggers><Trigger Property="IsMouseOver" Value="True"><Setter TargetName="ItemBorder" Property="Background" Value="{DynamicResource NavHoverBrush}" /></Trigger><Trigger Property="IsSelected" Value="True"><Setter TargetName="ItemBorder" Property="Background" Value="{DynamicResource NavSelectedBrush}" /><Setter Property="Foreground" Value="{DynamicResource NavSelectedTextBrush}" /></Trigger><Trigger Property="IsKeyboardFocusWithin" Value="True"><Setter TargetName="ItemBorder" Property="BorderBrush" Value="{DynamicResource AccentBrush}" /><Setter TargetName="ItemBorder" Property="BorderThickness" Value="1" /></Trigger></ControlTemplate.Triggers></ControlTemplate></Setter.Value></Setter>
        </Style>
        <Style TargetType="RadioButton"><Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" /></Style>
        <Style TargetType="ContextMenu">
            <Setter Property="Background" Value="{DynamicResource SurfaceBrush}" /><Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource LineBrush}" /><Setter Property="BorderThickness" Value="1" />
            <Setter Property="Template"><Setter.Value><ControlTemplate TargetType="ContextMenu"><Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="5" Padding="4"><StackPanel IsItemsHost="True" /></Border></ControlTemplate></Setter.Value></Setter>
        </Style>
        <Style TargetType="MenuItem">
            <Setter Property="Background" Value="{DynamicResource SurfaceBrush}" /><Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" /><Setter Property="Padding" Value="12,8" />
            <Setter Property="Template"><Setter.Value><ControlTemplate TargetType="MenuItem"><Border x:Name="MenuItemBorder" Background="{TemplateBinding Background}" CornerRadius="4" Padding="{TemplateBinding Padding}"><ContentPresenter ContentSource="Header" RecognizesAccessKey="True" /></Border><ControlTemplate.Triggers><Trigger Property="IsHighlighted" Value="True"><Setter TargetName="MenuItemBorder" Property="Background" Value="{DynamicResource NavHoverBrush}" /></Trigger><Trigger Property="IsEnabled" Value="False"><Setter Property="Opacity" Value="0.45" /></Trigger></ControlTemplate.Triggers></ControlTemplate></Setter.Value></Setter>
        </Style>
    </Window.Resources>
    <Grid>
        <Grid.ColumnDefinitions><ColumnDefinition Width="238" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
        <Border Grid.Column="0" Background="{DynamicResource SurfaceBrush}" BorderBrush="{DynamicResource LineBrush}" BorderThickness="0,0,1,0">
            <Grid><Grid.RowDefinitions><RowDefinition Height="92" /><RowDefinition Height="*" /><RowDefinition Height="Auto" /></Grid.RowDefinitions>
                <StackPanel Orientation="Horizontal" Margin="20" VerticalAlignment="Center"><Border Width="32" Height="32" Background="{DynamicResource AccentBrush}" CornerRadius="8"><TextBlock Text="&#xE71B;" FontFamily="Segoe Fluent Icons" Foreground="{DynamicResource OnAccentBrush}" HorizontalAlignment="Center" VerticalAlignment="Center" /></Border><StackPanel Margin="10,0" VerticalAlignment="Center"><TextBlock Text="Copilot Bridge" FontSize="17" FontWeight="SemiBold" LineHeight="22" /><TextBlock Text="v1.1.2 对话管理" FontSize="12" LineHeight="18" Foreground="{DynamicResource SubtleTextBrush}" /></StackPanel></StackPanel>
                <StackPanel Grid.Row="1" Margin="0,10">
                    <Button x:Name="OverviewNav" Style="{StaticResource NavButtonStyle}" Tag="overview" Click="Navigation_Click"><StackPanel Orientation="Horizontal"><TextBlock Text="&#xE80F;" FontFamily="Segoe Fluent Icons" Width="30" /><TextBlock Text="概览" /></StackPanel></Button>
                    <Button x:Name="HistoryNav" Style="{StaticResource NavButtonStyle}" Tag="history" Click="Navigation_Click"><StackPanel Orientation="Horizontal"><TextBlock Text="&#xE81C;" FontFamily="Segoe Fluent Icons" Width="30" /><TextBlock Text="对话管理" /></StackPanel></Button>
                    <Button x:Name="CollaborationNav" Style="{StaticResource NavButtonStyle}" Tag="collaboration" Click="Navigation_Click"><StackPanel Orientation="Horizontal"><TextBlock Text="&#xE902;" FontFamily="Segoe Fluent Icons" Width="30" /><TextBlock Text="协作默认设置" /></StackPanel></Button>
                    <Button x:Name="BrowserNav" Style="{StaticResource NavButtonStyle}" Tag="browser" Click="Navigation_Click"><StackPanel Orientation="Horizontal"><TextBlock Text="&#xE774;" FontFamily="Segoe Fluent Icons" Width="30" /><TextBlock Text="浏览器与模型" /></StackPanel></Button>
                    <Button x:Name="SettingsNav" Style="{StaticResource NavButtonStyle}" Tag="settings" Click="Navigation_Click"><StackPanel Orientation="Horizontal"><TextBlock Text="&#xE713;" FontFamily="Segoe Fluent Icons" Width="30" /><TextBlock Text="设置" /></StackPanel></Button>
                </StackPanel>
                <StackPanel Grid.Row="2" Margin="20,18"><Separator Background="{DynamicResource LineBrush}" /><TextBlock Text="数据保存在你的本地工作区" FontSize="11" Foreground="{DynamicResource MutedTextBrush}" Margin="0,12,0,0" /></StackPanel>
            </Grid>
        </Border>
        <Grid Grid.Column="1"><Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /><RowDefinition Height="*" /></Grid.RowDefinitions>
            <Grid Margin="32,18,32,0"><Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions><StackPanel><TextBlock x:Name="HeaderStatusText" Text="正在初始化" Foreground="{DynamicResource SubtleTextBrush}" VerticalAlignment="Center" /><TextBlock x:Name="BusyHintText" Foreground="{DynamicResource SubtleTextBrush}" FontSize="12" Margin="0,3,0,0" Visibility="Collapsed" /></StackPanel><ProgressBar x:Name="BusyProgress" Grid.Column="1" Width="130" Height="4" IsIndeterminate="True" Visibility="Collapsed" /></Grid>
            <Border x:Name="NoticeBorder" Grid.Row="1" Margin="32,10,32,0" Padding="14,10" Background="{DynamicResource NoticeInfoBackgroundBrush}" BorderBrush="{DynamicResource NoticeInfoBorderBrush}" BorderThickness="1" CornerRadius="7" Visibility="Collapsed"><Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions><TextBlock x:Name="NoticeText" TextWrapping="Wrap" Foreground="{DynamicResource NoticeInfoTextBrush}" VerticalAlignment="Center" /><Button x:Name="NoticeCloseButton" Grid.Column="1" Content="×" FontSize="18" FontWeight="SemiBold" Foreground="{DynamicResource NoticeInfoTextBrush}" Background="Transparent" BorderThickness="0" Padding="8,0,0,0" ToolTip="关闭提示" AutomationProperties.Name="关闭提示" Click="NoticeClose_Click" /></Grid></Border>
            <Grid Grid.Row="2">
                <Grid x:Name="OverviewPanel"><ScrollViewer VerticalScrollBarVisibility="Auto"><StackPanel Margin="36,28,36,40" MaxWidth="1040">
                    <TextBlock Text="概览" FontSize="28" FontWeight="SemiBold" /><TextBlock Text="检查后台连接状态，并管理专用 Copilot 标签页绑定。" Foreground="{DynamicResource SubtleTextBrush}" Margin="0,7,0,24" />
                    <Border Background="{DynamicResource SurfaceBrush}" BorderBrush="{DynamicResource LineBrush}" BorderThickness="1" CornerRadius="10"><Grid><Grid.RowDefinitions><RowDefinition Height="54" /><RowDefinition Height="54" /><RowDefinition Height="54" /><RowDefinition Height="54" /></Grid.RowDefinitions><Grid.ColumnDefinitions><ColumnDefinition Width="180" /><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                        <TextBlock Text="Edge 连接" Margin="20,0" VerticalAlignment="Center" Foreground="{DynamicResource SubtleTextBrush}" /><TextBlock x:Name="EdgeStatusText" Grid.Column="1" VerticalAlignment="Center" FontWeight="SemiBold" Text="尚未检查" /><Ellipse x:Name="EdgeStatusDot" Grid.Column="2" Width="9" Height="9" Fill="{DynamicResource StatusUnknownBrush}" Margin="20" />
                        <TextBlock Grid.Row="1" Text="专用标签页" Margin="20,0" VerticalAlignment="Center" Foreground="{DynamicResource SubtleTextBrush}" /><TextBlock x:Name="TabStatusText" Grid.Row="1" Grid.Column="1" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" Text="未绑定" />
                        <TextBlock Grid.Row="2" Text="Microsoft 365 登录" Margin="20,0" VerticalAlignment="Center" Foreground="{DynamicResource SubtleTextBrush}" /><TextBlock x:Name="LoginStatusText" Grid.Row="2" Grid.Column="1" VerticalAlignment="Center" Text="未知" />
                        <TextBlock Grid.Row="3" Text="页面当前模型" Margin="20,0" VerticalAlignment="Center" Foreground="{DynamicResource SubtleTextBrush}" /><TextBlock x:Name="ModelStatusText" Grid.Row="3" Grid.Column="1" VerticalAlignment="Center" Text="未知" />
                    </Grid></Border>
                    <StackPanel Orientation="Horizontal" Margin="0,14,0,4"><Button x:Name="RefreshButton" Content="刷新状态" Style="{StaticResource SecondaryButtonStyle}" Click="Refresh_Click" /></StackPanel>
                    <TextBlock x:Name="AutoRefreshStatusText" Text="自动刷新正在准备。" Foreground="{DynamicResource SubtleTextBrush}" FontSize="12" Margin="0,0,0,30" />
                    <TextBlock Text="标签页绑定" FontSize="18" FontWeight="SemiBold" /><TextBlock Text="将 Bridge 绑定到当前已登录的专用 Copilot 标签页。" Foreground="{DynamicResource SubtleTextBrush}" Margin="0,6,0,12" /><Border Background="{DynamicResource SurfaceBrush}" BorderBrush="{DynamicResource LineBrush}" BorderThickness="1" CornerRadius="9" Padding="18,15"><Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions><StackPanel><TextBlock Text="当前绑定" Foreground="{DynamicResource SubtleTextBrush}" FontSize="12" /><TextBlock x:Name="BoundUrlText" Text="未绑定" Margin="0,6,20,0" TextTrimming="CharacterEllipsis" /></StackPanel><Button x:Name="BindButton" Grid.Column="1" Content="绑定当前 Copilot 标签页" Style="{StaticResource PrimaryButtonStyle}" Click="Bind_Click" /></Grid></Border>
                </StackPanel></ScrollViewer></Grid>
                <Grid x:Name="HistoryPanel" Visibility="Collapsed" Margin="28,20,28,28"><Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="*" /></Grid.RowDefinitions>
                    <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions><StackPanel><TextBlock Text="对话管理" FontSize="28" FontWeight="SemiBold" /><TextBlock Text="集中管理本地 Markdown 对话，并可显式导入当前打开的旧网页对话。" Foreground="{DynamicResource SubtleTextBrush}" Margin="0,6,0,0" /></StackPanel><Button x:Name="ImportConversationButton" Grid.Column="1" Content="导入对话" Style="{StaticResource PrimaryButtonStyle}" VerticalAlignment="Center" Click="ImportConversation_Click" /></Grid>
                    <Grid Grid.Row="1" Margin="0,22,0,0"><Grid.ColumnDefinitions><ColumnDefinition x:Name="HistoryProjectColumn" Width="220" /><ColumnDefinition x:Name="HistoryConversationColumn" Width="280" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                        <Border Background="{DynamicResource SurfaceBrush}" BorderBrush="{DynamicResource LineBrush}" BorderThickness="1" CornerRadius="10" Margin="0,0,12,0"><Grid><Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="*" /></Grid.RowDefinitions><StackPanel Margin="14"><TextBlock Text="项目" FontWeight="SemiBold" /><TextBlock Text="项目文件夹" FontSize="12" Foreground="{DynamicResource SubtleTextBrush}" Margin="0,4,0,10" /><TextBlock Text="项目名称" FontSize="12" Foreground="{DynamicResource SubtleTextBrush}" Margin="0,0,0,4" /><TextBox x:Name="NewProjectTextBox" AutomationProperties.Name="项目名称" Margin="0,0,0,8" ToolTip="输入项目名称" /><Button x:Name="NewProjectButton" Content="创建项目" Style="{StaticResource SecondaryButtonStyle}" Click="NewProject_Click" /></StackPanel><ListBox x:Name="ProjectListBox" Grid.Row="1" Margin="8,0,8,8" BorderThickness="0" SelectionChanged="Project_SelectionChanged" PreviewMouseRightButtonDown="ProjectListBox_PreviewMouseRightButtonDown" ContextMenuOpening="ProjectListBox_ContextMenuOpening" AllowDrop="True" Drop="ProjectListBox_Drop" ToolTip="可将会话拖到项目中归类"><ListBox.ContextMenu><ContextMenu><MenuItem x:Name="PinProjectMenuItem" Header="置顶" Click="PinProjectMenuItem_Click" /><MenuItem x:Name="RenameProjectMenuItem" Header="重命名" Click="RenameProjectMenuItem_Click" /><MenuItem x:Name="DeleteProjectMenuItem" Header="删除" Click="DeleteProjectMenuItem_Click" /></ContextMenu></ListBox.ContextMenu><ListBox.ItemTemplate><DataTemplate><Border Background="{DynamicResource SurfaceBrush}" BorderBrush="{DynamicResource LineBrush}" BorderThickness="1" CornerRadius="6" Padding="12,9" Margin="0,3"><DockPanel><TextBlock Text="&#xE8B7;" FontFamily="Segoe Fluent Icons" Foreground="{DynamicResource SubtleTextBrush}" Margin="0,0,10,0" /><TextBlock Text="{Binding Name}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" /><TextBlock DockPanel.Dock="Right" Text="&#xE840;" FontFamily="Segoe Fluent Icons" Foreground="{DynamicResource AccentTextBrush}" ToolTip="已置顶"><TextBlock.Style><Style TargetType="TextBlock"><Setter Property="Visibility" Value="Collapsed" /><Style.Triggers><DataTrigger Binding="{Binding IsPinned}" Value="True"><Setter Property="Visibility" Value="Visible" /></DataTrigger></Style.Triggers></Style></TextBlock.Style></TextBlock></DockPanel></Border></DataTemplate></ListBox.ItemTemplate></ListBox></Grid></Border>
                        <Border Grid.Column="1" Background="{DynamicResource SurfaceBrush}" BorderBrush="{DynamicResource LineBrush}" BorderThickness="1" CornerRadius="10" Margin="0,0,12,0"><Grid><Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="*" /></Grid.RowDefinitions><TextBlock Text="会话（可拖入项目）" FontWeight="SemiBold" Margin="14" /><ListBox x:Name="ConversationListBox" Grid.Row="1" Margin="8,0,8,8" BorderThickness="0" SelectionChanged="Conversation_SelectionChanged" PreviewMouseLeftButtonDown="ConversationListBox_PreviewMouseLeftButtonDown" PreviewMouseRightButtonDown="ConversationListBox_PreviewMouseRightButtonDown" PreviewMouseMove="ConversationListBox_PreviewMouseMove"><ListBox.ContextMenu><ContextMenu><MenuItem x:Name="RenameConversationMenuItem" Header="重命名" Click="RenameConversationMenuItem_Click" /><MenuItem x:Name="DeleteConversationMenuItem" Header="删除" Click="DeleteConversationMenuItem_Click" /></ContextMenu></ListBox.ContextMenu><ListBox.ItemTemplate><DataTemplate><StackPanel Margin="6"><TextBlock Text="{Binding DisplayTitle}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" /><TextBlock Text="{Binding CopilotTitle}" Foreground="{DynamicResource SubtleTextBrush}" FontSize="11" TextTrimming="CharacterEllipsis" /><TextBlock Text="{Binding LastModel}" Foreground="{DynamicResource AccentTextBrush}" FontSize="11" Margin="0,3,0,0" /></StackPanel></DataTemplate></ListBox.ItemTemplate></ListBox></Grid></Border>
                        <Border Grid.Column="2" Background="{DynamicResource SurfaceBrush}" BorderBrush="{DynamicResource LineBrush}" BorderThickness="1" CornerRadius="10"><Grid><Grid.RowDefinitions><RowDefinition Height="*" /></Grid.RowDefinitions><TextBlock x:Name="ConversationEmptyText" Text="选择或创建一个即时会话" Foreground="{DynamicResource SubtleTextBrush}" HorizontalAlignment="Center" VerticalAlignment="Center" /><ScrollViewer x:Name="ConversationDetailPanel" Visibility="Collapsed" VerticalScrollBarVisibility="Auto"><StackPanel Margin="22"><TextBlock Text="本地显示名称" FontSize="12" Foreground="{DynamicResource SubtleTextBrush}" Margin="0,0,0,4" /><Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions><TextBox x:Name="ConversationTitleTextBox" AutomationProperties.Name="本地显示名称" FontSize="21" FontWeight="SemiBold" BorderThickness="0" Padding="0" /><Button x:Name="RenameConversationButton" Grid.Column="1" Content="保存名称" Style="{StaticResource SecondaryButtonStyle}" Click="RenameConversation_Click" /></Grid>
                            <TextBlock x:Name="CopilotTitleText" Foreground="{DynamicResource SubtleTextBrush}" Margin="0,10,0,0" /><TextBlock x:Name="CopilotTitleHistoryText" Foreground="{DynamicResource SubtleTextBrush}" FontSize="12" Margin="0,3,0,0" /><TextBlock x:Name="ConversationMetaText" Foreground="{DynamicResource AccentTextBrush}" FontSize="12" Margin="0,8,0,0" />
                            <StackPanel Orientation="Horizontal" Margin="0,18,0,0"><TextBlock Text="移动到：" VerticalAlignment="Center" /><ComboBox x:Name="MoveProjectComboBox" AutomationProperties.Name="移动会话到项目" Width="170" DisplayMemberPath="Name" SelectedValuePath="Id" /><Button x:Name="MoveConversationButton" Content="移动" Style="{StaticResource SecondaryButtonStyle}" Margin="8,0,0,0" Click="MoveConversation_Click" /><Button Content="复制 Markdown" Style="{StaticResource SecondaryButtonStyle}" Margin="8,0,0,0" Click="CopyConversation_Click" /></StackPanel>
                            <Separator Margin="0,20" /><TextBlock Text="会话内检索" FontWeight="SemiBold" /><Grid Margin="0,8,0,0"><Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions><TextBox x:Name="ConversationSearchTextBox" AutomationProperties.Name="会话内检索关键词" /><Button Grid.Column="1" Content="检索" Style="{StaticResource SecondaryButtonStyle}" Margin="8,0,0,0" Click="SearchConversation_Click" /></Grid><TextBlock x:Name="SearchResultsText" TextWrapping="Wrap" Foreground="{DynamicResource SubtleTextBrush}" Margin="0,8,0,0" />
                            <Separator Margin="0,20" /><TextBlock Text="Markdown 对话" FontWeight="SemiBold" /><TextBox x:Name="ConversationMarkdownTextBox" Margin="0,8,0,0" IsReadOnly="True" AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" MinHeight="280" FontFamily="Cascadia Mono, Consolas" FontSize="12" />
                        </StackPanel></ScrollViewer></Grid></Border>
                    </Grid>
                </Grid>
                <Grid x:Name="CollaborationPanel" Visibility="Collapsed"><ScrollViewer VerticalScrollBarVisibility="Auto"><StackPanel Margin="36,28,36,40" MaxWidth="900"><TextBlock Text="协作默认设置" FontSize="28" FontWeight="SemiBold" /><TextBlock Text="这里定义新会话的默认行为；即时会话记录会保存实际使用的模式和模型。" Foreground="{DynamicResource SubtleTextBrush}" Margin="0,7,0,26" />
                    <TextBlock Text="征询策略" FontSize="16" FontWeight="SemiBold" /><ComboBox x:Name="PolicyComboBox" Width="360" HorizontalAlignment="Left" Margin="0,10,0,0"><ComboBoxItem Content="关闭" /><ComboBoxItem Content="仅手动（默认）" /><ComboBoxItem Content="Codex 可自动征询" /><ComboBoxItem Content="关键设计必须征询" /></ComboBox>
                    <Separator Margin="0,28" /><TextBlock Text="默认协作模式" FontSize="16" FontWeight="SemiBold" /><RadioButton x:Name="AssistRadio" GroupName="CollaborationMode" IsChecked="True" Content="Assist — 快速聚焦的第二意见" Margin="0,12,0,0" /><RadioButton x:Name="OutsourceRadio" GroupName="CollaborationMode" Content="Outsource — 有限回合的开放式推理" Margin="0,10,0,0" /><RadioButton x:Name="ReviewRadio" GroupName="CollaborationMode" Content="Review — 两个隔离 reviewer" Margin="0,10,0,0" /><Button x:Name="SaveCollaborationButton" Content="保存协作默认设置" Style="{StaticResource PrimaryButtonStyle}" HorizontalAlignment="Left" Margin="0,24,0,0" Click="Save_Click" />
                </StackPanel></ScrollViewer></Grid>
                <Grid x:Name="BrowserPanel" Visibility="Collapsed"><ScrollViewer VerticalScrollBarVisibility="Auto"><StackPanel Margin="36,28,36,40" MaxWidth="900"><TextBlock Text="浏览器与模型" FontSize="28" FontWeight="SemiBold" /><TextBlock Text="配置模型回退顺序、菜单等待与回复超时。" Foreground="{DynamicResource SubtleTextBrush}" Margin="0,7,0,26" />
                    <TextBlock Text="模型优先级" FontSize="16" FontWeight="SemiBold" /><TextBlock Text="拖动选项卡排序；仅在上方模型不可用时回退。" Foreground="{DynamicResource SubtleTextBrush}" Margin="0,6,0,8" /><ListBox x:Name="ModelPriorityListBox" BorderThickness="0" AllowDrop="True" PreviewMouseLeftButtonDown="ModelPriorityListBox_PreviewMouseLeftButtonDown" PreviewMouseMove="ModelPriorityListBox_PreviewMouseMove" Drop="ModelPriorityListBox_Drop"><ListBox.ItemTemplate><DataTemplate><Border Background="{DynamicResource SurfaceBrush}" BorderBrush="{DynamicResource LineBrush}" BorderThickness="1" CornerRadius="6" Padding="12,9" Margin="0,3"><DockPanel><TextBlock Text="&#xE8FD;" FontFamily="Segoe Fluent Icons" Foreground="{DynamicResource SubtleTextBrush}" Margin="0,0,10,0" /><TextBlock Text="{Binding}" FontWeight="SemiBold" /></DockPanel></Border></DataTemplate></ListBox.ItemTemplate></ListBox>
                    <Grid Margin="0,16,0,0"><Grid.ColumnDefinitions><ColumnDefinition Width="220" /><ColumnDefinition Width="220" /><ColumnDefinition Width="220" /></Grid.ColumnDefinitions><StackPanel><TextBlock Text="菜单最短等待（ms）" Foreground="{DynamicResource SubtleTextBrush}" /><TextBox x:Name="MenuMinimumTextBox" Width="190" Margin="0,7,0,0" /></StackPanel><StackPanel Grid.Column="1"><TextBlock Text="菜单最大等待（ms）" Foreground="{DynamicResource SubtleTextBrush}" /><TextBox x:Name="MenuMaximumTextBox" Width="190" Margin="0,7,0,0" /></StackPanel><StackPanel Grid.Column="2"><TextBlock Text="回复超时（秒）" Foreground="{DynamicResource SubtleTextBrush}" /><TextBox x:Name="ReplyTimeoutTextBox" Width="190" Margin="0,7,0,0" /></StackPanel></Grid>
                    <StackPanel Margin="0,16,0,0"><TextBlock Text="沟通轮次上限" Foreground="{DynamicResource SubtleTextBrush}" /><TextBox x:Name="ConversationTurnLimitTextBox" Width="190" Margin="0,7,0,0" /><TextBlock Text="每个协作模式最多执行的沟通轮次（1–20）。" Foreground="{DynamicResource SubtleTextBrush}" FontSize="12" Margin="0,5,0,0" /></StackPanel>
                    <Button x:Name="SaveBrowserButton" Content="保存浏览器与模型设置" Style="{StaticResource PrimaryButtonStyle}" HorizontalAlignment="Left" Margin="0,24,0,0" Click="Save_Click" />
                </StackPanel></ScrollViewer></Grid>
                <Grid x:Name="SettingsPanel" Visibility="Collapsed"><ScrollViewer VerticalScrollBarVisibility="Auto"><StackPanel Margin="36,28,36,40" MaxWidth="900">
                    <TextBlock Text="设置" FontSize="28" FontWeight="SemiBold" /><TextBlock Text="立即切换应用界面语言；该偏好会保存在本机设置中。" Foreground="{DynamicResource SubtleTextBrush}" Margin="0,7,0,26" />
                    <TextBlock Text="显示语言" FontSize="16" FontWeight="SemiBold" /><ComboBox x:Name="LanguageComboBox" Width="280" HorizontalAlignment="Left" Margin="0,10,0,0" SelectionChanged="Language_SelectionChanged"><ComboBoxItem Content="中文" /><ComboBoxItem Content="English" /></ComboBox>
                    <TextBlock Text="主题" FontSize="16" FontWeight="SemiBold" Margin="0,24,0,0" /><TextBlock Text="深色主题采用 Codex 风格的低眩光深色画布。" Foreground="{DynamicResource SubtleTextBrush}" Margin="0,6,0,0" /><ComboBox x:Name="ThemeComboBox" AutomationProperties.Name="主题" Width="280" HorizontalAlignment="Left" Margin="0,10,0,0" SelectionChanged="Theme_SelectionChanged"><ComboBoxItem Content="浅色（默认）" /><ComboBoxItem Content="深色（Codex）" /></ComboBox>
                    <Separator Margin="0,28" /><TextBlock Text="本地会话工作区" FontSize="16" FontWeight="SemiBold" /><TextBlock Text="即时会话以一会话一 Markdown 文件保存在此处；旧网页历史不会自动导入。" Foreground="{DynamicResource SubtleTextBrush}" Margin="0,6,0,10" /><Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions><TextBox x:Name="WorkspaceDirectoryTextBox" /><Button x:Name="BrowseWorkspaceButton" Grid.Column="1" Content="浏览" Style="{StaticResource SecondaryButtonStyle}" Margin="8,0,0,0" Click="BrowseWorkspace_Click" /></Grid>
                    <Button x:Name="SaveSettingsButton" Content="保存设置" Style="{StaticResource PrimaryButtonStyle}" HorizontalAlignment="Left" Margin="0,24,0,0" Click="Save_Click" />
                    <Separator Margin="0,30,0,0" /><TextBlock Text="即时咨询" FontSize="18" FontWeight="SemiBold" Margin="0,24,0,0" /><TextBlock Text="发送后会保存发送内容、Copilot 回复和已验证的实际模型；不会自动导入旧网页历史。" Foreground="{DynamicResource SubtleTextBrush}" Margin="0,6,0,12" /><TextBox x:Name="TestPromptTextBox" Height="120" AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" Text="这是 Copilot Bridge v1.1 即时会话测试。请只回复：COPILOT_BRIDGE_V11_OK" /><Button x:Name="TestButton" Content="发送并记录即时咨询" Style="{StaticResource PrimaryButtonStyle}" HorizontalAlignment="Left" Margin="0,12,0,0" Click="Test_Click" />
                </StackPanel></ScrollViewer></Grid>
            </Grid>
        </Grid>
    </Grid>
</Window>
