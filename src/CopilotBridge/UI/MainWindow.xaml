<Window x:Class="CopilotBridge.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Copilot Bridge"
        Width="1240" Height="780" MinWidth="980" MinHeight="640"
        WindowStartupLocation="CenterScreen"
        Background="#F5F6F8"
        FontFamily="Segoe UI Variable Text, Segoe UI"
        Foreground="#1D232F"
        Loaded="Window_Loaded">
    <Window.Resources>
        <SolidColorBrush x:Key="AccentBrush" Color="#0A6CFF" />
        <SolidColorBrush x:Key="SubtleTextBrush" Color="#697586" />
        <SolidColorBrush x:Key="LineBrush" Color="#E4E7EC" />

        <Style x:Key="NavButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="46" />
            <Setter Property="Margin" Value="10,3" />
            <Setter Property="Padding" Value="14,0" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="#4D5868" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Border" Background="{TemplateBinding Background}" CornerRadius="8">
                            <ContentPresenter Margin="{TemplateBinding Padding}"
                                              VerticalAlignment="Center"
                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#EDF0F4" />
                            </Trigger>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="Border" Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                                <Setter TargetName="Border" Property="BorderThickness" Value="1" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="38" />
            <Setter Property="Padding" Value="18,0" />
            <Setter Property="Background" Value="{StaticResource AccentBrush}" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Border" Background="{TemplateBinding Background}" CornerRadius="7">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="Opacity" Value="0.88" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Border" Property="Opacity" Value="0.45" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SecondaryButtonStyle" TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
            <Setter Property="Background" Value="White" />
            <Setter Property="Foreground" Value="{StaticResource AccentBrush}" />
            <Setter Property="BorderBrush" Value="#B7D3FF" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Border" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="7">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#F2F7FF" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Border" Property="Opacity" Value="0.45" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Padding" Value="10,8" />
            <Setter Property="BorderBrush" Value="#D7DCE3" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Background" Value="White" />
            <Setter Property="FontSize" Value="14" />
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Height" Value="38" />
            <Setter Property="Padding" Value="8,4" />
            <Setter Property="BorderBrush" Value="#D7DCE3" />
            <Setter Property="Background" Value="White" />
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="64" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#F8F9FB" BorderBrush="{StaticResource LineBrush}" BorderThickness="0,0,0,1">
            <Grid Margin="24,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Border Width="32" Height="32" CornerRadius="16" Background="{StaticResource AccentBrush}" VerticalAlignment="Center">
                    <TextBlock Text="&#xE71B;" FontFamily="Segoe Fluent Icons" Foreground="White"
                               FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center" />
                </Border>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="12,0,0,0">
                    <TextBlock Text="Copilot Bridge" FontSize="18" FontWeight="SemiBold" VerticalAlignment="Center" />
                    <Border Margin="12,0,0,0" Padding="8,3" CornerRadius="10" Background="#E7F6ED">
                        <TextBlock Text="本地" Foreground="#168447" FontSize="12" />
                    </Border>
                </StackPanel>
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <ProgressBar x:Name="BusyProgress" Width="92" Height="3" IsIndeterminate="True"
                                 Visibility="Collapsed" Margin="0,0,16,0" />
                    <TextBlock x:Name="HeaderStatusText" Text="正在初始化" Foreground="{StaticResource SubtleTextBrush}"
                               FontSize="13" VerticalAlignment="Center" />
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="236" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="#F8F9FB" BorderBrush="{StaticResource LineBrush}" BorderThickness="0,0,1,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <TextBox Margin="16,18,16,12" Height="38" IsReadOnly="True" Text="搜索设置"
                             Foreground="#9AA3AF" Background="#F0F2F5" BorderThickness="0" />
                    <StackPanel Grid.Row="1" Margin="6,4">
                        <Button x:Name="OverviewNav" Style="{StaticResource NavButtonStyle}" Tag="overview" Click="Navigation_Click"
                                Background="#EAF3FF" Foreground="{StaticResource AccentBrush}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE80F;" FontFamily="Segoe Fluent Icons" FontSize="17" Width="30" />
                                <TextBlock Text="概览" FontSize="15" />
                            </StackPanel>
                        </Button>
                        <Button x:Name="CollaborationNav" Style="{StaticResource NavButtonStyle}" Tag="collaboration" Click="Navigation_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE902;" FontFamily="Segoe Fluent Icons" FontSize="17" Width="30" />
                                <TextBlock Text="协作" FontSize="15" />
                            </StackPanel>
                        </Button>
                        <Button x:Name="BrowserNav" Style="{StaticResource NavButtonStyle}" Tag="browser" Click="Navigation_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE774;" FontFamily="Segoe Fluent Icons" FontSize="17" Width="30" />
                                <TextBlock Text="浏览器与模型" FontSize="15" />
                            </StackPanel>
                        </Button>
                    </StackPanel>
                    <StackPanel Grid.Row="2" Margin="20,0,20,20">
                        <Separator Margin="0,0,0,14" Background="{StaticResource LineBrush}" />
                        <TextBlock Text="Phase 5 · Manual modes" FontSize="12" Foreground="{StaticResource SubtleTextBrush}" />
                        <TextBlock Text="数据仅保存在本机" FontSize="11" Foreground="#9AA3AF" Margin="0,4,0,0" />
                    </StackPanel>
                </Grid>
            </Border>

            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Border x:Name="NoticeBorder" Grid.Row="0" Margin="32,20,32,0" Padding="14,10"
                        Background="#FFF4E5" BorderBrush="#FFD7A3" BorderThickness="1" CornerRadius="7"
                        Visibility="Collapsed">
                    <TextBlock x:Name="NoticeText" TextWrapping="Wrap" Foreground="#7A4A0A" />
                </Border>

                <Grid Grid.Row="1">
                    <Grid x:Name="OverviewPanel">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel Margin="36,28,36,40" MaxWidth="1080" HorizontalAlignment="Stretch">
                                <TextBlock Text="概览" FontSize="28" FontWeight="SemiBold" />
                                <TextBlock Text="查看 Edge 连接、专用标签页和最近一次咨询。"
                                           Foreground="{StaticResource SubtleTextBrush}" Margin="0,7,0,24" />

                                <Border Background="White" BorderBrush="{StaticResource LineBrush}" BorderThickness="1" CornerRadius="10">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="58" /><RowDefinition Height="58" />
                                            <RowDefinition Height="58" /><RowDefinition Height="58" />
                                        </Grid.RowDefinitions>
                                        <Grid.ColumnDefinitions><ColumnDefinition Width="180" /><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                                        <TextBlock Grid.Row="0" Text="Edge 连接" Margin="20,0" VerticalAlignment="Center" Foreground="{StaticResource SubtleTextBrush}" />
                                        <TextBlock x:Name="EdgeStatusText" Grid.Row="0" Grid.Column="1" Text="尚未检查" VerticalAlignment="Center" FontWeight="SemiBold" />
                                        <Ellipse x:Name="EdgeStatusDot" Grid.Row="0" Grid.Column="2" Width="9" Height="9" Fill="#A8B0BC" Margin="20" />
                                        <Separator Grid.Row="0" Grid.ColumnSpan="3" VerticalAlignment="Bottom" Background="{StaticResource LineBrush}" />

                                        <TextBlock Grid.Row="1" Text="专用标签页" Margin="20,0" VerticalAlignment="Center" Foreground="{StaticResource SubtleTextBrush}" />
                                        <TextBlock x:Name="TabStatusText" Grid.Row="1" Grid.Column="1" Text="未绑定" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
                                        <Separator Grid.Row="1" Grid.ColumnSpan="3" VerticalAlignment="Bottom" Background="{StaticResource LineBrush}" />

                                        <TextBlock Grid.Row="2" Text="Microsoft 365 登录" Margin="20,0" VerticalAlignment="Center" Foreground="{StaticResource SubtleTextBrush}" />
                                        <TextBlock x:Name="LoginStatusText" Grid.Row="2" Grid.Column="1" Text="未知" VerticalAlignment="Center" />
                                        <Separator Grid.Row="2" Grid.ColumnSpan="3" VerticalAlignment="Bottom" Background="{StaticResource LineBrush}" />

                                        <TextBlock Grid.Row="3" Text="当前模型" Margin="20,0" VerticalAlignment="Center" Foreground="{StaticResource SubtleTextBrush}" />
                                        <TextBlock x:Name="ModelStatusText" Grid.Row="3" Grid.Column="1" Text="未知" VerticalAlignment="Center" />
                                    </Grid>
                                </Border>

                                <StackPanel Orientation="Horizontal" Margin="0,14,0,28">
                                    <Button x:Name="RefreshButton" Content="刷新状态" Style="{StaticResource SecondaryButtonStyle}" Click="Refresh_Click" />
                                    <Button x:Name="BindButton" Content="绑定当前 Copilot 标签页" Style="{StaticResource PrimaryButtonStyle}" Click="Bind_Click" Margin="10,0,0,0" />
                                </StackPanel>

                                <TextBlock Text="测试咨询" FontSize="18" FontWeight="SemiBold" />
                                <TextBlock Text="使用当前 GUI 设置执行一次当前模式咨询；发送状态不确定时绝不自动重试。"
                                           Foreground="{StaticResource SubtleTextBrush}" Margin="0,6,0,12" />
                                <TextBox x:Name="TestPromptTextBox" Height="86" AcceptsReturn="True" TextWrapping="Wrap"
                                         VerticalScrollBarVisibility="Auto"
                                         Text="这是 Copilot Bridge Phase 3 GUI 测试。请只回复：COPILOT_BRIDGE_PHASE3_OK" />
                                <Button x:Name="TestButton" Content="发送测试咨询" Style="{StaticResource PrimaryButtonStyle}"
                                        HorizontalAlignment="Left" Margin="0,12,0,28" Click="Test_Click" />

                                <TextBlock Text="最近咨询" FontSize="18" FontWeight="SemiBold" />
                                <Border Background="White" BorderBrush="{StaticResource LineBrush}" BorderThickness="1" CornerRadius="10" Margin="0,12,0,0" Padding="20,16">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="150" /><ColumnDefinition Width="150" />
                                            <ColumnDefinition Width="140" /><ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel><TextBlock Text="时间" Foreground="{StaticResource SubtleTextBrush}" FontSize="12" /><TextBlock x:Name="RecentTimeText" Text="—" Margin="0,6,0,0" /></StackPanel>
                                        <StackPanel Grid.Column="1"><TextBlock Text="模型" Foreground="{StaticResource SubtleTextBrush}" FontSize="12" /><TextBlock x:Name="RecentModelText" Text="—" Margin="0,6,0,0" /></StackPanel>
                                        <StackPanel Grid.Column="2"><TextBlock Text="状态" Foreground="{StaticResource SubtleTextBrush}" FontSize="12" /><TextBlock x:Name="RecentStateText" Text="尚无记录" Margin="0,6,0,0" /></StackPanel>
                                        <StackPanel Grid.Column="3"><TextBlock Text="结果预览（不持久化）" Foreground="{StaticResource SubtleTextBrush}" FontSize="12" /><TextBlock x:Name="RecentReplyText" Text="—" Margin="0,6,0,0" TextTrimming="CharacterEllipsis" /></StackPanel>
                                    </Grid>
                                </Border>
                            </StackPanel>
                        </ScrollViewer>
                    </Grid>

                    <Grid x:Name="CollaborationPanel" Visibility="Collapsed">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel Margin="36,28,36,40" MaxWidth="900">
                                <TextBlock Text="协作" FontSize="28" FontWeight="SemiBold" />
                                <TextBlock Text="决定何时允许咨询，以及下一次咨询采用哪种分工。"
                                           Foreground="{StaticResource SubtleTextBrush}" Margin="0,7,0,26" />

                                <TextBlock Text="征询策略" FontSize="16" FontWeight="SemiBold" />
                                <TextBlock Text="策略只控制是否允许调用；不会改变 Copilot 模型优先级。"
                                           Foreground="{StaticResource SubtleTextBrush}" Margin="0,6,0,10" />
                                <ComboBox x:Name="PolicyComboBox" Width="360" HorizontalAlignment="Left">
                                    <ComboBoxItem Content="关闭" />
                                    <ComboBoxItem Content="仅手动（默认）" />
                                    <ComboBoxItem Content="Codex 可自动征询" />
                                    <ComboBoxItem Content="关键设计必须征询" />
                                </ComboBox>

                                <Separator Margin="0,28" Background="{StaticResource LineBrush}" />
                                <TextBlock Text="协作模式" FontSize="16" FontWeight="SemiBold" />
                                <TextBlock Text="模式由你手动选择；MCP 无权临时切换。"
                                           Foreground="{StaticResource SubtleTextBrush}" Margin="0,6,0,12" />

                                <Border Background="White" BorderBrush="#9BC2FF" BorderThickness="1" CornerRadius="9" Padding="16,14">
                                    <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="Auto" /><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                                        <RadioButton x:Name="AssistRadio" GroupName="CollaborationMode" IsChecked="True" VerticalAlignment="Center" />
                                        <StackPanel Grid.Column="1" Margin="12,0"><TextBlock Text="Assist" FontWeight="SemiBold" /><TextBlock Text="Codex 主导，Copilot 回答一个聚焦问题" Foreground="{StaticResource SubtleTextBrush}" Margin="0,4,0,0" /></StackPanel>
                                        <Border Grid.Column="2" Background="#E7F1FF" CornerRadius="10" Padding="8,3"><TextBlock Text="可用" Foreground="{StaticResource AccentBrush}" FontSize="12" /></Border>
                                    </Grid>
                                </Border>
                                <Border Background="White" BorderBrush="{StaticResource LineBrush}" BorderThickness="1" CornerRadius="9" Padding="16,14" Margin="0,10,0,0">
                                    <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="Auto" /><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                                        <RadioButton x:Name="OutsourceRadio" GroupName="CollaborationMode" VerticalAlignment="Center" />
                                        <StackPanel Grid.Column="1" Margin="12,0"><TextBlock Text="Outsource" FontWeight="SemiBold" /><TextBlock Text="Copilot 负责开放式推理，Codex 最终核验" Foreground="{StaticResource SubtleTextBrush}" Margin="0,4,0,0" /></StackPanel>
                                        <Border Grid.Column="2" Background="#EAF7EF" CornerRadius="10" Padding="8,3"><TextBlock Text="可用" Foreground="#176B3A" FontSize="12" /></Border>
                                    </Grid>
                                </Border>
                                <Border Background="White" BorderBrush="{StaticResource LineBrush}" BorderThickness="1" CornerRadius="9" Padding="16,14" Margin="0,10,0,0">
                                    <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="Auto" /><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                                        <RadioButton x:Name="ReviewRadio" GroupName="CollaborationMode" VerticalAlignment="Center" />
                                        <StackPanel Grid.Column="1" Margin="12,0"><TextBlock Text="Review" FontWeight="SemiBold" /><TextBlock Text="两个隔离 reviewer 会话，Codex 汇总裁决" Foreground="{StaticResource SubtleTextBrush}" Margin="0,4,0,0" /></StackPanel>
                                        <Border Grid.Column="2" Background="#EAF7EF" CornerRadius="10" Padding="8,3"><TextBlock Text="可用" Foreground="#176B3A" FontSize="12" /></Border>
                                    </Grid>
                                </Border>

                                <Button x:Name="SaveCollaborationButton" Content="保存协作设置" Style="{StaticResource PrimaryButtonStyle}"
                                        HorizontalAlignment="Left" Margin="0,22,0,0" Click="Save_Click" />
                            </StackPanel>
                        </ScrollViewer>
                    </Grid>

                    <Grid x:Name="BrowserPanel" Visibility="Collapsed">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel Margin="36,28,36,40" MaxWidth="900">
                                <TextBlock Text="浏览器与模型" FontSize="28" FontWeight="SemiBold" />
                                <TextBlock Text="只连接日常 Edge 中已登录的专用 Copilot 标签页。"
                                           Foreground="{StaticResource SubtleTextBrush}" Margin="0,7,0,26" />

                                <TextBlock Text="标签页绑定" FontSize="16" FontWeight="SemiBold" />
                                <Border Background="White" BorderBrush="{StaticResource LineBrush}" BorderThickness="1" CornerRadius="9" Margin="0,12,0,0" Padding="18,15">
                                    <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                                        <StackPanel><TextBlock Text="当前绑定" Foreground="{StaticResource SubtleTextBrush}" FontSize="12" /><TextBlock x:Name="BoundUrlText" Text="未绑定" Margin="0,6,20,0" TextTrimming="CharacterEllipsis" /></StackPanel>
                                        <Button Grid.Column="1" Content="重新绑定" Style="{StaticResource SecondaryButtonStyle}" Click="Bind_Click" />
                                    </Grid>
                                </Border>

                                <Separator Margin="0,28" Background="{StaticResource LineBrush}" />
                                <TextBlock Text="模型优先级" FontSize="16" FontWeight="SemiBold" />
                                <TextBlock Text="菜单打开后至少等待 2 秒；高优先级不可用时才向下回退。"
                                           Foreground="{StaticResource SubtleTextBrush}" Margin="0,6,0,12" />
                                <Border Background="White" BorderBrush="{StaticResource LineBrush}" BorderThickness="1" CornerRadius="9">
                                    <StackPanel>
                                        <Grid Height="52"><Grid.ColumnDefinitions><ColumnDefinition Width="58" /><ColumnDefinition Width="*" /><ColumnDefinition Width="120" /></Grid.ColumnDefinitions><TextBlock Text="1" Foreground="{StaticResource AccentBrush}" FontWeight="SemiBold" HorizontalAlignment="Center" VerticalAlignment="Center" /><TextBlock Grid.Column="1" Text="Opus" VerticalAlignment="Center" FontWeight="SemiBold" /><TextBlock Grid.Column="2" Text="Claude" Foreground="{StaticResource SubtleTextBrush}" VerticalAlignment="Center" /></Grid>
                                        <Separator Background="{StaticResource LineBrush}" />
                                        <Grid Height="52"><Grid.ColumnDefinitions><ColumnDefinition Width="58" /><ColumnDefinition Width="*" /><ColumnDefinition Width="120" /></Grid.ColumnDefinitions><TextBlock Text="2" Foreground="{StaticResource AccentBrush}" FontWeight="SemiBold" HorizontalAlignment="Center" VerticalAlignment="Center" /><TextBlock Grid.Column="1" Text="GPT 5.6 Think deeper" VerticalAlignment="Center" FontWeight="SemiBold" /><TextBlock Grid.Column="2" Text="OpenAI" Foreground="{StaticResource SubtleTextBrush}" VerticalAlignment="Center" /></Grid>
                                        <Separator Background="{StaticResource LineBrush}" />
                                        <Grid Height="52"><Grid.ColumnDefinitions><ColumnDefinition Width="58" /><ColumnDefinition Width="*" /><ColumnDefinition Width="120" /></Grid.ColumnDefinitions><TextBlock Text="3" Foreground="{StaticResource AccentBrush}" FontWeight="SemiBold" HorizontalAlignment="Center" VerticalAlignment="Center" /><TextBlock Grid.Column="1" Text="深度思考" VerticalAlignment="Center" FontWeight="SemiBold" /><TextBlock Grid.Column="2" Text="Copilot 路由" Foreground="{StaticResource SubtleTextBrush}" VerticalAlignment="Center" /></Grid>
                                    </StackPanel>
                                </Border>

                                <Grid Margin="0,26,0,0">
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="220" /><ColumnDefinition Width="220" /><ColumnDefinition Width="220" /></Grid.ColumnDefinitions>
                                    <StackPanel><TextBlock Text="菜单最短等待（ms）" Foreground="{StaticResource SubtleTextBrush}" Margin="0,0,0,7" /><TextBox x:Name="MenuMinimumTextBox" Text="2000" Width="190" HorizontalAlignment="Left" /></StackPanel>
                                    <StackPanel Grid.Column="1"><TextBlock Text="菜单最大等待（ms）" Foreground="{StaticResource SubtleTextBrush}" Margin="0,0,0,7" /><TextBox x:Name="MenuMaximumTextBox" Text="6000" Width="190" HorizontalAlignment="Left" /></StackPanel>
                                    <StackPanel Grid.Column="2"><TextBlock Text="回复超时（秒）" Foreground="{StaticResource SubtleTextBrush}" Margin="0,0,0,7" /><TextBox x:Name="ReplyTimeoutTextBox" Text="300" Width="190" HorizontalAlignment="Left" /></StackPanel>
                                </Grid>
                                <Button x:Name="SaveBrowserButton" Content="保存浏览器设置" Style="{StaticResource PrimaryButtonStyle}"
                                        HorizontalAlignment="Left" Margin="0,22,0,0" Click="Save_Click" />
                            </StackPanel>
                        </ScrollViewer>
                    </Grid>
                </Grid>
            </Grid>
        </Grid>
    </Grid>
</Window>
